<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/posterita_line"
    app:cardBackgroundColor="@color/posterita_paper"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Customer avatar -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_user"
                android:scaleType="fitCenter"
                android:contentDescription="Customer" />
        </FrameLayout>

        <!-- Name + Phone -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/text_customer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Customer Name"
                style="@style/TextAppearance.Posterita.Body"
                android:fontFamily="@font/lexend_medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/text_customer_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                style="@style/TextAppearance.Posterita.Tiny"
                android:textColor="@color/posterita_muted"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Select button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_select"
            style="@style/Widget.Posterita.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Select"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
