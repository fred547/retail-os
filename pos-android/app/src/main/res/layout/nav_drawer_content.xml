<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_paper"
    tools:ignore="HardcodedText">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Logo header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_splash"
                android:scaleType="fitCenter"
                android:contentDescription="Posterita" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Posterita"
                style="@style/TextAppearance.Posterita.Heading" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:background="@color/posterita_line" />

        <!-- Home -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/chip_unselected_bg"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_drawer"
                android:scaleType="fitCenter"
                android:contentDescription="Home"
                app:tint="@color/posterita_ink" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Home"
                style="@style/TextAppearance.Posterita.Body" />
        </LinearLayout>

        <!-- Orders -->
        <LinearLayout
            android:id="@+id/nav_orders"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/chip_unselected_bg"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/order"
                android:scaleType="fitCenter"
                android:contentDescription="Orders"
                app:tint="@color/posterita_ink" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Orders"
                style="@style/TextAppearance.Posterita.Body" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:background="@color/posterita_line" />

        <!-- Open Cash Drawer -->
        <LinearLayout
            android:id="@+id/nav_open_drawer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/chip_unselected_bg"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/till"
                android:scaleType="fitCenter"
                android:contentDescription="Open Cash Drawer"
                app:tint="@color/posterita_ink" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Open Cash Drawer"
                style="@style/TextAppearance.Posterita.Body" />
        </LinearLayout>

        <!-- Close Till -->
        <LinearLayout
            android:id="@+id/nav_close_till"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/chip_unselected_bg"
            android:foreground="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/till"
                android:scaleType="fitCenter"
                android:contentDescription="Close Till"
                app:tint="@color/posterita_ink" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Close Till"
                style="@style/TextAppearance.Posterita.Body" />
        </LinearLayout>

        <!-- Hidden IDs for binding compat -->
        <View android:id="@+id/nav_pos" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_logout" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_hold_orders" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_kitchen_orders" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_settings" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_cloud_sync" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_get_update" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_about" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_help" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_admin_settings" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_icon" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_label" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_spinner" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_status" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_progress_container" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_progress_text" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <View android:id="@+id/nav_sync_progress_bar" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

    </LinearLayout>
</ScrollView>
