<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="HardcodedText">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".Activities.ProductActivity">

        <ImageView
            android:id="@+id/drawer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_drawer"
            android:visibility="visible"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />



        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consuser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/img_del"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="14dp"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginEnd="@dimen/_10sdp"
                android:src="@drawable/ic_del"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="14dp"
                android:src="@drawable/ic_scanner"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toStartOf="@id/button_clear_cart"
                app:layout_constraintTop_toTopOf="@id/button_clear_cart"
                app:layout_constraintBottom_toBottomOf="@id/button_clear_cart"/>
            <ImageView
                android:id="@+id/button_clear_cart"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="14dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="@id/img_del"
                android:src="@drawable/clear"
                app:layout_constraintTop_toTopOf="@+id/img_del"
                app:layout_constraintBottom_toBottomOf="@id/img_del"
                android:layout_marginEnd="@dimen/_5sdp"
                app:tint="@color/txt_color" />

            <TextView
                android:id="@+id/txtuser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/_7sdp"
                android:text="Fahan Ali"
                android:textColor="@color/black"
                app:layout_constraintEnd_toStartOf="@+id/img_del"
                app:layout_constraintTop_toTopOf="@+id/img_del" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <EditText
            android:id="@+id/textfield_search_product"
            android:layout_width="@dimen/_150sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:background="@drawable/white_start_rad"
            android:elevation="@dimen/_5sdp"
            android:hint="Search"
            android:maxLines="1"
            android:paddingStart="@dimen/_15sdp"
            android:textSize="@dimen/_15ssp"
            app:layout_constraintTop_toTopOf="parent"

            app:layout_constraintStart_toEndOf="@+id/drawer"
            android:textColor="@color/black" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/button_search_product"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="@dimen/_15sdp"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/blue_end_corner"
            app:layout_constraintStart_toEndOf="@+id/textfield_search_product">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_search"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/catrc"
            android:layout_width="@dimen/_100sdp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/textfield_search_product"
            android:layout_marginTop="@dimen/_15ssp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/_5sdp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/product"
            android:layout_width="@dimen/_145sdp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/textfield_search_product"
            android:layout_marginTop="@dimen/_15ssp"
            app:layout_constraintStart_toEndOf="@id/catrc"
            android:layout_marginStart="@dimen/_5sdp"/>
        <TextView
            android:id="@+id/cart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toEndOf="@id/button_search_product"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="Cart"
            android:textSize="@dimen/_20ssp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/_10sdp"/>
        <ImageView
            android:id="@+id/img"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            app:layout_constraintStart_toEndOf="@+id/button_search_product"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintEnd_toStartOf="@id/txtusers"
            app:layout_constraintTop_toBottomOf="@id/cart"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:src="@drawable/ic_selectuser_blue"/>
        <TextView
            android:id="@+id/txtusers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select User"
            android:layout_marginStart="@dimen/_10sdp"
            app:layout_constraintStart_toEndOf="@+id/img"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cart"
            android:textColor="@color/posterita_primary"
            android:textSize="@dimen/_13ssp"
            android:textStyle="bold"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/crdproduct"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="5dp"
            tools:listitem="@layout/item"
            app:layout_constraintTop_toBottomOf="@+id/txtusers"
            app:layout_constraintBottom_toTopOf="@id/consbotom"
            app:layout_constraintStart_toEndOf="@id/product"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consbotom"
            android:layout_width="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/product"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_20sdp"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@color/white">
            <TextView
                android:id="@+id/txt_sub_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/black"
                android:text="Sub total"
                app:layout_constraintBottom_toTopOf="@id/text_view_tax_total"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/txt_tex_totoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/black"
                android:text="Tax total"
                app:layout_constraintBottom_toTopOf="@id/text_view_grand_total"

                android:layout_marginEnd="@dimen/_15sdp"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/text_view_subtotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/black"
                android:text="rs 11"
                app:layout_constraintBottom_toTopOf="@id/text_view_tax_total"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/text_view_tax_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_14ssp"
                android:textColor="@color/black"
                android:text="00.00"
                app:layout_constraintBottom_toTopOf="@id/txt_discount_total"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/txt_discount_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_14ssp"
                android:textColor="#E53935"
                android:text="Discount"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/text_view_grand_total"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/text_view_discount_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_14ssp"
                android:textColor="#E53935"
                android:text="-0.00"
                android:visibility="gone"
                app:layout_constraintBottom_toTopOf="@id/text_view_grand_total"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textColor="@color/black"
                android:fontFamily="@font/lexend_medium"
                app:layout_constraintBottom_toTopOf="@+id/button_pay_order"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginBottom="@dimen/_5sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:textSize="@dimen/_18ssp"/>
            <TextView
                android:id="@+id/text_view_grand_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RS"
                android:textColor="@color/black"
                android:fontFamily="@font/lexend_medium"
                app:layout_constraintBottom_toTopOf="@+id/button_pay_order"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="@dimen/_5sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:textSize="@dimen/_18ssp"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/button_hold_order"
                android:layout_width="0dp"
                android:layout_marginBottom="@dimen/_15sdp"
                android:layout_marginStart="@dimen/_35sdp"
                android:layout_height="48dp"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintEnd_toStartOf="@+id/button_pay_order"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/stroke_btn">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hold Order"
                    android:textSize="@dimen/_11ssp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/black"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/button_pay_order"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_50sdp"
                android:layout_marginBottom="@dimen/_15sdp"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/button_hold_order"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/btn_rounded">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pay"
                    android:textSize="@dimen/_11ssp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/white"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="wrap_content"
        android:id="@+id/nav"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/navigation_menu" />

</androidx.drawerlayout.widget.DrawerLayout>