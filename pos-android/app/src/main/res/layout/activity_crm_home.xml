<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CRM"
            android:textSize="20sp"
            android:fontFamily="@font/lexend_semibold"
            android:textColor="@color/posterita_ink"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/buttonHelp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_help_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Help"
            android:layout_marginEnd="4dp" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Summary cards -->
            <LinearLayout
                android:id="@+id/summaryCards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/posterita_line">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:id="@+id/textTotalCustomers" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                            android:fontFamily="@font/lexend_bold" android:textColor="@color/posterita_primary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Customers" android:textSize="12sp" android:textColor="@color/posterita_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/posterita_line">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:id="@+id/textLoyaltyMembers" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                            android:fontFamily="@font/lexend_bold" android:textColor="#8B5CF6" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Loyalty" android:textSize="12sp" android:textColor="@color/posterita_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/posterita_line">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:id="@+id/textTotalPoints" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="0" android:textSize="24sp"
                            android:fontFamily="@font/lexend_bold" android:textColor="@color/posterita_secondary" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Pts" android:textSize="12sp" android:textColor="@color/posterita_muted" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Loyalty Program Detail Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLoyaltyProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Loyalty Program"
                            android:textSize="14sp"
                            android:fontFamily="@font/lexend_semibold"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/textLoyaltyStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textSize="12sp"
                            android:fontFamily="@font/lexend_medium" />
                    </LinearLayout>

                    <!-- Config details grid: 2x2 -->
                    <LinearLayout
                        android:id="@+id/layoutLoyaltyDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="10dp"
                        android:visibility="gone">

                        <!-- Row 1: Earn rate + Redemption value -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Earn Rate"
                                    android:textSize="11sp"
                                    android:textColor="@color/posterita_muted" />
                                <TextView
                                    android:id="@+id/textEarnRate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/lexend_medium"
                                    android:textColor="@color/posterita_ink" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Point Value"
                                    android:textSize="11sp"
                                    android:textColor="@color/posterita_muted" />
                                <TextView
                                    android:id="@+id/textRedemptionRate"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/lexend_medium"
                                    android:textColor="@color/posterita_ink" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Row 2: Min redeem + Welcome bonus -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="8dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Min Redeem"
                                    android:textSize="11sp"
                                    android:textColor="@color/posterita_muted" />
                                <TextView
                                    android:id="@+id/textMinRedeem"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/lexend_medium"
                                    android:textColor="@color/posterita_ink" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="8dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Welcome Bonus"
                                    android:textSize="11sp"
                                    android:textColor="@color/posterita_muted" />
                                <TextView
                                    android:id="@+id/textWelcomeBonus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textSize="14sp"
                                    android:fontFamily="@font/lexend_medium"
                                    android:textColor="@color/posterita_ink" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Inactive message -->
                    <TextView
                        android:id="@+id/textLoyaltyInactive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loyalty program is not configured. Set it up in the web console."
                        android:textSize="12sp"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginTop="6dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Lookup Search -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quick Points Lookup"
                        android:textSize="14sp"
                        android:fontFamily="@font/lexend_semibold"
                        android:textColor="@color/posterita_ink" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <EditText
                            android:id="@+id/editQuickSearch"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:hint="Name or phone..."
                            android:textSize="14sp"
                            android:inputType="text"
                            android:background="@drawable/bg_edit_text_rounded"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:layout_marginEnd="8dp"
                            android:singleLine="true"
                            android:imeOptions="actionSearch" />

                        <ImageButton
                            android:id="@+id/buttonQuickSearch"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_search"
                            android:background="@drawable/bg_button_primary_round"
                            android:contentDescription="Search"
                            android:padding="10dp" />
                    </LinearLayout>

                    <!-- Quick search result -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardQuickResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#8B5CF6"
                        app:cardBackgroundColor="#FBF8FF">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/textQuickResultInitial"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:gravity="center"
                                    android:textSize="16sp"
                                    android:fontFamily="@font/lexend_bold"
                                    android:textColor="@android:color/white"
                                    android:background="@drawable/badge_background"
                                    android:layout_marginEnd="10dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">
                                    <TextView
                                        android:id="@+id/textQuickResultName"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:textSize="14sp"
                                        android:fontFamily="@font/lexend_medium"
                                        android:textColor="@color/posterita_ink"
                                        android:maxLines="1"
                                        android:ellipsize="end" />
                                    <TextView
                                        android:id="@+id/textQuickResultPhone"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:textSize="12sp"
                                        android:textColor="@color/posterita_muted" />
                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:gravity="end">
                                    <TextView
                                        android:id="@+id/textQuickResultPoints"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="18sp"
                                        android:fontFamily="@font/lexend_bold"
                                        android:textColor="#8B5CF6" />
                                    <TextView
                                        android:id="@+id/textQuickResultValue"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="11sp"
                                        android:textColor="@color/posterita_muted" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- Redeemable indicator -->
                            <TextView
                                android:id="@+id/textQuickResultRedeemable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:textSize="11sp"
                                android:fontFamily="@font/lexend_medium"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- No result message -->
                    <TextView
                        android:id="@+id/textQuickNoResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No customer found"
                        android:textSize="12sp"
                        android:textColor="@color/posterita_muted"
                        android:gravity="center"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <LinearLayout
                android:id="@+id/actionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonSearchCustomer"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Search / Add"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    app:icon="@drawable/ic_search"
                    app:iconGravity="textStart"
                    app:backgroundTint="@color/posterita_primary"
                    app:cornerRadius="10dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonLoyaltyConfig"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Loyalty Config"
                    android:textAllCaps="false"
                    android:textSize="13sp"
                    app:cornerRadius="10dp" />
            </LinearLayout>

            <!-- Section header -->
            <TextView
                android:id="@+id/textCustomersHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top Customers"
                android:textSize="14sp"
                android:fontFamily="@font/lexend_medium"
                android:textColor="@color/posterita_muted"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp" />

            <!-- Customer list (inside ScrollView, so wrap_content) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerCustomers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="4dp"
                android:clipToPadding="false"
                android:paddingBottom="16dp"
                android:nestedScrollingEnabled="false" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/layoutEmptyCustomers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                android:minHeight="120dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="No customers yet" android:textSize="16sp" android:textColor="@color/posterita_muted" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
