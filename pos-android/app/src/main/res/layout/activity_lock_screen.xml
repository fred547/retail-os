<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg">

    <!-- Logo + Title -->
    <LinearLayout
        android:id="@+id/layout_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_pin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_splash"
            android:scaleType="fitCenter"
            android:contentDescription="Posterita" />

        <TextView
            android:id="@+id/text_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Welcome back"
            style="@style/TextAppearance.Posterita.Heading" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Enter your PIN to continue"
            style="@style/TextAppearance.Posterita.Body.Muted" />
    </LinearLayout>

    <!-- PIN display -->
    <LinearLayout
        android:id="@+id/layout_pin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/layout_header"
        app:layout_constraintBottom_toTopOf="@id/grid_numpad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:id="@+id/dot1" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginEnd="14dp" android:background="@drawable/bg_internet_dot" />
        <View android:id="@+id/dot2" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginEnd="14dp" android:background="@drawable/bg_internet_dot" />
        <View android:id="@+id/dot3" android:layout_width="14dp" android:layout_height="14dp" android:layout_marginEnd="14dp" android:background="@drawable/bg_internet_dot" />
        <View android:id="@+id/dot4" android:layout_width="14dp" android:layout_height="14dp" android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Error message -->
    <TextView
        android:id="@+id/text_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/posterita_error"
        style="@style/TextAppearance.Posterita.Micro"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_pin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Numpad -->
    <GridLayout
        android:id="@+id/grid_numpad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_1" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="1" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_2" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="2" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_3" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="3" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_4" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="4" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_5" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="5" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_6" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="6" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_7" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="7" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_8" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="8" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_9" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="9" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_clear" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="C" android:textSize="20sp" android:textColor="@color/posterita_error" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_0" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="0" android:textSize="20sp" />
        <com.google.android.material.button.MaterialButton android:id="@+id/btn_backspace" style="@style/Widget.Posterita.Button.Outlined" android:layout_width="72dp" android:layout_height="54dp" android:layout_margin="4dp" android:text="⌫" android:textSize="20sp" />
    </GridLayout>

    <!-- Enter button (for PINs longer than 4 digits) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_enter"
        style="@style/Widget.Posterita.Button.Pay"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:text="Enter"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/grid_numpad"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "Not me" link -->
    <TextView
        android:id="@+id/text_not_me"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Not me? Switch account"
        android:textColor="@color/posterita_primary"
        style="@style/TextAppearance.Posterita.Micro"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
