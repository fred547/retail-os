<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/relativeLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTintMode="screen">
    </com.journeyapps.barcodescanner.DecoratedBarcodeView>

    <ImageButton
        android:id="@+id/btn_switch_camera"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="16dp"
        android:alpha="0.7"
        android:background="@android:color/transparent"
        android:contentDescription="Switch Camera"
        android:padding="16dp"
        android:src="@drawable/baseline_cameraswitch_48" />


    <!-- Transparent ImageButton for Flashlight Control -->
    <ImageButton
        android:id="@+id/btn_toogle_flashlight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:alpha="0.7"
        android:background="@android:color/transparent"
        android:contentDescription="Flashlight Toggle"
        android:padding="16dp"
        android:src="@drawable/baseline_flash_on_48" />

    <!-- Start of Action Buttons -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/button_my_cart"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_40sdp"
        android:layout_marginStart="@dimen/_50sdp"
        android:layout_marginEnd="@dimen/_50sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:background="@drawable/btn_rounded"
        android:layout_alignParentBottom="true">

        <TextView
            android:id="@+id/button_my_cart_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:layout_marginBottom="@dimen/_8sdp"
            android:fontFamily="@font/lexend_medium"
            android:text="My Cart"
            android:textColor="@color/white"
            android:textSize="@dimen/_17ssp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <!-- End of Action Buttons -->

</RelativeLayout>
