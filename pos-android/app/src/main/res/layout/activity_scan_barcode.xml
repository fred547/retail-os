<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_ink">

    <!-- Camera preview with built-in viewfinder box -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_controls" />

    <!-- Top bar: flash + title + switch camera -->
    <LinearLayout
        android:id="@+id/layout_top_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_toogle_flashlight"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Flashlight Toggle"
            android:padding="10dp"
            android:src="@drawable/baseline_flash_on_48"
            app:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Barcode"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_medium" />

            <TextView
                android:id="@+id/text_scan_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-scanning · Point at barcode"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Connectivity indicator -->
        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_internet_dot" />

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch Camera"
            android:padding="10dp"
            android:src="@drawable/baseline_cameraswitch_48"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Product scanned toast (overlays bottom of camera, auto-dismisses) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_scan_toast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#E6FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_controls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/posterita_secondary"
                android:contentDescription="Added" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_toast_product_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/posterita_ink"
                    android:textSize="13sp"
                    android:fontFamily="@font/lexend_medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/text_toast_product_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/posterita_primary"
                    android:textSize="12sp"
                    android:fontFamily="@font/lexend_medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_toast_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/posterita_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Hidden scan result views for binding compat -->
    <LinearLayout
        android:id="@+id/layout_scan_result"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/text_scanned_product"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/text_scanned_barcode"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/button_scan_again"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scanner box overlay with red laser line -->
    <FrameLayout
        android:id="@+id/layout_scanner_overlay"
        android:layout_width="240dp"
        android:layout_height="160dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/camera_preview"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview">

        <!-- Scanner box border -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/scanner_box_border" />

        <!-- Red laser line -->
        <View
            android:id="@+id/view_laser_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/posterita_error" />
    </FrameLayout>

    <!-- Bottom: Take Picture + Cart button with badge -->
    <LinearLayout
        android:id="@+id/layout_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:background="@color/posterita_paper"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Scan button — force capture/decode -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_take_picture"
            style="@style/Widget.Posterita.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:icon="@drawable/ic_barcode_scan"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            android:text="Scan" />

        <!-- My Cart button with item count -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_my_cart"
                style="@style/Widget.Posterita.Button.Pay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:icon="@drawable/ic_shopping_cart"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconTint="@color/white"
                android:text="MY CART" />

            <!-- Badge -->
            <TextView
                android:id="@+id/text_cart_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:translationX="6dp"
                android:translationY="-6dp"
                android:minWidth="22dp"
                android:minHeight="22dp"
                android:gravity="center"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:background="@drawable/badge_background_red"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:fontFamily="@font/lexend_extrabold"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <!-- Hidden binding compat -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_cancel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <!-- button_take_picture is now in layout_bottom_controls -->
    <TextView
        android:id="@+id/button_my_cart_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
