<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_ink">

    <!-- Camera preview with built-in viewfinder box -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/camera_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layout_scan_result" />

    <!-- Top bar: flash + title + switch camera -->
    <LinearLayout
        android:id="@+id/layout_top_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_toogle_flashlight"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Flashlight Toggle"
            android:padding="10dp"
            android:src="@drawable/baseline_flash_on_48"
            app:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan Barcode"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="@font/lexend_medium" />

            <TextView
                android:id="@+id/text_scan_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-scanning · Point at barcode"
                android:textColor="#AAFFFFFF"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_switch_camera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Switch Camera"
            android:padding="10dp"
            android:src="@drawable/baseline_cameraswitch_48"
            app:tint="@android:color/white" />
    </LinearLayout>

    <!-- Scan result banner (shows after scan, green) -->
    <LinearLayout
        android:id="@+id/layout_scan_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/posterita_secondary_light"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_controls">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_check_circle"
            app:tint="@color/posterita_secondary"
            android:contentDescription="Scanned" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_scanned_product"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product scanned"
                android:textColor="@color/posterita_secondary"
                android:textSize="14sp"
                android:fontFamily="@font/lexend_medium" />

            <TextView
                android:id="@+id/text_scanned_barcode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/posterita_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/button_scan_again"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="SCAN AGAIN"
            android:textColor="@color/posterita_secondary"
            android:textSize="12sp"
            android:fontFamily="@font/lexend_medium"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/layout_bottom_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:background="@color/posterita_paper"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Cancel button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_cancel"
            style="@style/Widget.Posterita.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Cancel" />

        <!-- My Cart button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_my_cart"
            style="@style/Widget.Posterita.Button.Pay"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:text="My Cart" />

        <!-- Hidden for binding compat -->
        <TextView
            android:id="@+id/button_my_cart_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
