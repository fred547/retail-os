<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/posterita_paper"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title -->
            <TextView
                android:id="@+id/txt_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discount on Total"
                style="@style/TextAppearance.Posterita.Heading"
                android:textColor="@color/posterita_primary"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Quick percentage presets -->
            <GridLayout
                android:id="@+id/grid_presets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:rowCount="2"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_5"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:text="5%" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_10"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:text="10%" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_15"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:text="15%" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_20"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:text="20%" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_25"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:text="25%" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_50"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:text="50%" />
            </GridLayout>

            <!-- Custom input: percentage or fixed amount -->
            <LinearLayout
                android:id="@+id/layout_custom_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edit_percentage"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="0"
                    android:textSize="18sp"
                    android:textColor="@color/posterita_ink"
                    android:gravity="center"
                    android:background="@drawable/bg_search_bar"
                    android:padding="8dp"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" %"
                    android:textSize="16sp"
                    android:textColor="@color/posterita_ink"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="14dp" />

                <EditText
                    android:id="@+id/edit_amount"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:inputType="numberDecimal"
                    android:hint="0.00"
                    android:textSize="18sp"
                    android:textColor="@color/posterita_ink"
                    android:gravity="center"
                    android:background="@drawable/bg_search_bar"
                    android:padding="8dp"
                    android:importantForAutofill="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" amt"
                    android:textSize="13sp"
                    android:textColor="@color/posterita_muted"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Hidden numpad views for binding compat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                android:orientation="horizontal">
                <View android:id="@+id/num_0" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_1" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_2" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_3" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_4" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_5" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_6" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_7" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_8" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_9" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_dot" android:layout_width="0dp" android:layout_height="0dp" />
                <View android:id="@+id/num_backspace" android:layout_width="0dp" android:layout_height="0dp" />
            </LinearLayout>

            <!-- Promo code button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_promo_code"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:text="Have a promo code?"
                android:textSize="13sp" />

            <!-- Action buttons: Remove | Cancel | Apply -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_remove"
                    style="@style/Widget.Posterita.Button.Danger"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Remove" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_cancel"
                    style="@style/Widget.Posterita.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="Cancel" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_apply"
                    style="@style/Widget.Posterita.Button.Pay"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Apply" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
