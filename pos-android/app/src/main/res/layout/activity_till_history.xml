<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg"
    tools:context=".ui.activity.TillHistoryActivity">

    <!-- Top bar: back + "Till Sessions" + connectivity dot -->
    <LinearLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="@color/posterita_paper"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/buttonBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/posterita_ink" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Till Sessions"
            style="@style/TextAppearance.Posterita.Heading" />

        <!-- Connectivity indicator -->
        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Hidden toolbar for drawer binding compat -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Date selector pill -->
    <LinearLayout
        android:id="@+id/layout_date_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <TextView
            android:id="@+id/text_date_filter"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="\uD83D\uDCC5 Today \u25BE"
            android:textSize="13sp"
            android:fontFamily="@font/lexend_medium"
            android:textColor="@color/posterita_primary"
            android:background="@drawable/btn_outline_rounded"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Status filter chips -->
    <HorizontalScrollView
        android:id="@+id/scroll_status_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/layout_date_selector">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/Widget.Posterita.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOpen"
                style="@style/Widget.Posterita.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Open" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipClosed"
                style="@style/Widget.Posterita.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Closed" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDiscrepancy"
                style="@style/Widget.Posterita.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Discrepancy"
                app:chipBackgroundColor="@color/posterita_error_light"
                app:chipStrokeColor="@color/posterita_error" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Result count -->
    <TextView
        android:id="@+id/txtResultCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:textSize="13sp"
        android:textColor="@color/posterita_muted"
        app:layout_constraintTop_toBottomOf="@id/scroll_status_chips"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Till sessions list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_tills"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@+id/txtResultCount"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scroll_status_chips"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scroll_status_chips"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.3"
            android:contentDescription="No till sessions"
            android:src="@drawable/till"
            app:tint="@color/posterita_muted" />

        <TextView
            android:id="@+id/txtEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No till sessions"
            android:textColor="@color/posterita_ink"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEmptySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Till sessions will appear here"
            android:textColor="@color/posterita_muted"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
