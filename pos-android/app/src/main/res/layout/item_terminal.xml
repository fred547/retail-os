<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardTerminal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/posterita_line"
    app:cardBackgroundColor="@color/posterita_paper"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Terminal icon -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="14dp">

            <View
                android:id="@+id/iconBg"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_rounded_square" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/till"
                app:tint="@color/white"
                android:contentDescription="Terminal" />
        </FrameLayout>

        <!-- Text content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTerminalName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                style="@style/TextAppearance.Posterita.Body"
                android:fontFamily="@font/lexend_medium"
                android:textColor="@color/posterita_ink"
                tools:text="POS Terminal 1" />

            <TextView
                android:id="@+id/tvTerminalStore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                style="@style/TextAppearance.Posterita.Tiny"
                android:textColor="@color/posterita_muted"
                tools:text="Store: Main Street" />

            <TextView
                android:id="@+id/tvTerminalPrefix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                style="@style/TextAppearance.Posterita.Micro"
                android:textColor="@color/posterita_muted"
                tools:text="Prefix: INV" />
        </LinearLayout>

        <!-- Info column -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginStart="8dp">

            <TextView
                android:id="@+id/tvActiveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"
                android:textSize="10sp"
                android:fontFamily="@font/lexend_semibold"
                android:textColor="@color/posterita_secondary"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvTerminalFloat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                style="@style/TextAppearance.Posterita.Micro"
                android:textColor="@color/posterita_muted"
                tools:text="Float: 500.00" />
        </LinearLayout>

        <!-- Chevron -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="›"
            android:textSize="20sp"
            android:textColor="@color/posterita_muted" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
