<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/posterita_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Stock Transfer"
            android:textSize="20sp"
            android:fontFamily="@font/lexend_semibold"
            android:textColor="@color/posterita_ink"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/buttonHelp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_help_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Help"
            android:layout_marginEnd="4dp" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Scan product -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonScan"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Scan Product Barcode"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:icon="@drawable/ic_search"
                app:iconGravity="textStart"
                app:backgroundTint="@color/posterita_primary"
                app:cornerRadius="12dp" />

            <!-- Selected product info -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Scan a product to transfer"
                        android:textSize="16sp"
                        android:fontFamily="@font/lexend_medium"
                        android:textColor="@color/posterita_ink" />

                    <TextView
                        android:id="@+id/textProductStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/textProductLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Destination store -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Transfer to"
                android:textSize="14sp"
                android:fontFamily="@font/lexend_medium"
                android:textColor="@color/posterita_muted"
                android:layout_marginTop="16dp" />

            <Spinner
                android:id="@+id/spinnerDestStore"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/btn_outline_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <!-- Quantity -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Quantity to transfer"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTransferQty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notes -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Notes (optional)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTransferNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Transfer button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonTransfer"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Transfer Stock"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="@color/posterita_secondary"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
