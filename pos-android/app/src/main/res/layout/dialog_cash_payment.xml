<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amount Due"
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_amount_due"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textColor="@color/black"
        android:fontFamily="@font/lexend_medium"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Quick Amount Buttons -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Quick Amount"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="8dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:id="@+id/layout_quick_amounts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amount Tendered"
        android:textSize="13sp"
        android:textColor="#666666"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/edit_amount_tendered"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:textSize="22sp"
        android:textColor="@color/black"
        android:padding="12dp"
        android:background="@drawable/btn_outline_rounded" />

    <TextView
        android:id="@+id/text_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#4CAF50"
        android:fontFamily="@font/lexend_medium"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>
