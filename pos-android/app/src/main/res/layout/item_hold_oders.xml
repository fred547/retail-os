<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    style="@style/Widget.Posterita.Card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Row 1: Customer name + Hold ID/time  |  Total amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: Customer + hold info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_customer_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Walk-in"
                    android:textColor="@color/posterita_ink"
                    style="@style/TextAppearance.Posterita.Subheading" />

                <TextView
                    android:id="@+id/txt_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Hold #1 · 5 min ago"
                    style="@style/TextAppearance.Posterita.Caption" />

            </LinearLayout>

            <!-- Right: Total amount -->
            <TextView
                android:id="@+id/txtamount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs 0.00"
                android:textColor="@color/posterita_ink"
                style="@style/TextAppearance.Posterita.Subheading" />

        </LinearLayout>

        <!-- Row 2: Note/reason (if any) -->
        <TextView
            android:id="@+id/txtdes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text=""
            android:textStyle="italic"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone"
            style="@style/TextAppearance.Posterita.Body.Muted" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="@color/posterita_line" />

        <!-- Row 3: RESUME + CANCEL buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Cancel"
                android:layout_marginEnd="8dp"
                style="@style/Widget.Posterita.Button.Danger" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_resume"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Resume"
                style="@style/Widget.Posterita.Button.Primary" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
