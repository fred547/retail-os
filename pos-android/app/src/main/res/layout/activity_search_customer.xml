<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/posterita_bg"
    tools:context=".Activities.SearchCustomerActivity">

    <!-- Start of Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <EditText
            android:id="@+id/textfield_search_customer"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_16sdp"
            android:layout_weight="1"
            android:background="@drawable/white_start_rad"
            android:elevation="@dimen/_5sdp"
            android:hint="Search by phone number"
            android:inputType="phone"
            android:maxLines="1"
            android:paddingStart="@dimen/_10sdp"
            android:paddingEnd="@dimen/_10sdp"
            android:textColor="@color/posterita_ink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_search_customer"
            style="@style/Widget.Posterita.Button.Primary"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="@dimen/_15sdp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:cornerRadius="12dp" />

    </LinearLayout>

    <!-- End of Search bar -->

    <!-- Empty state for customer search -->
    <include
        layout="@layout/empty_state"
        android:id="@+id/empty_state_customers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="visible" />

    <!-- Start of RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_search_customer_results"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/_15sdp"
        android:layout_marginRight="@dimen/_15sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:layout_weight="1"
        android:visibility="gone" />
    <!-- End of RecyclerView -->

    <!-- Start of Action Buttons -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_add_customer"
        style="@style/Widget.Posterita.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="@dimen/_50sdp"
        android:layout_marginEnd="@dimen/_50sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:text="Add Customer" />
    <!-- End of Action Buttons -->

</LinearLayout>