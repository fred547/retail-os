<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg"
    tools:context=".Activities.SearchCustomerActivity">

    <!-- Top bar: ← back + Customer Lookup + connectivity dot -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/posterita_paper"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/button_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/posterita_ink" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Customer Lookup"
            style="@style/TextAppearance.Posterita.Heading" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/text_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Search by phone number or name"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        style="@style/TextAppearance.Posterita.Tiny"
        android:textColor="@color/posterita_muted"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar" />

    <!-- Search bar -->
    <LinearLayout
        android:id="@+id/layout_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/text_subtitle">

        <EditText
            android:id="@+id/textfield_search_customer"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_search_bar"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="@color/posterita_muted"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:hint="Phone number or name..."
            android:textColorHint="@color/posterita_muted"
            android:textColor="@color/posterita_ink"
            android:textSize="14sp"
            android:maxLines="1"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:importantForAutofill="no" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_search_customer"
            style="@style/Widget.Posterita.Button.Primary"
            android:layout_width="48dp"
            android:layout_height="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:cornerRadius="14dp" />
    </LinearLayout>

    <!-- Results count -->
    <TextView
        android:id="@+id/text_results_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        style="@style/TextAppearance.Posterita.Nano"
        android:textColor="@color/posterita_muted"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_search" />

    <!-- Empty state -->
    <include
        layout="@layout/empty_state"
        android:id="@+id/empty_state_customers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/text_results_count"
        app:layout_constraintBottom_toTopOf="@id/button_add_customer" />

    <!-- Customer results list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_search_customer_results"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/text_results_count"
        app:layout_constraintBottom_toTopOf="@id/button_add_customer" />

    <!-- Add Customer button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_add_customer"
        style="@style/Widget.Posterita.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="14dp"
        android:text="+ Create New Customer"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
