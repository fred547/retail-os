<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/layout_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/posterita_paper"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/button_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/posterita_ink" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Terminal"
            style="@style/TextAppearance.Posterita.Heading" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_top_bar"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom_buttons">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ======= TERMINAL SECTION ======= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TERMINAL"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_terminal_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Terminal Name *"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_terminal_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_receipt_prefix"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Receipt Prefix"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_receipt_prefix"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_float_amount"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Float Amount"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_float_amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_store"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Store"
                        android:visibility="gone"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actv_store"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ======= POS CONFIGURATION SECTION ======= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="POS CONFIGURATION"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp" />

                    <!-- Product Columns (1-4) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Product Columns"
                                android:textSize="15sp"
                                android:textColor="@color/posterita_ink" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Products per row (1-4)"
                                android:textSize="12sp"
                                android:textColor="@color/posterita_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/btn_col_1"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="1"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_col_2"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="2"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_col_3"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="3"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_col_4"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="4"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Category Columns (2-6) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Category Columns"
                                android:textSize="15sp"
                                android:textColor="@color/posterita_ink" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Columns for categories (2-6)"
                                android:textSize="12sp"
                                android:textColor="@color/posterita_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/btn_catcol_2"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="2"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_catcol_3"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="3"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_catcol_4"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="4"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_catcol_5"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="5"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_catcol_6"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="6"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Category Max Lines (1-4) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Category Max Lines"
                                android:textSize="15sp"
                                android:textColor="@color/posterita_ink" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max lines for category chips (1-4)"
                                android:textSize="12sp"
                                android:textColor="@color/posterita_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/btn_cat_1"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="1"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_cat_2"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="2"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_cat_3"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="3"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_cat_4"
                                android:layout_width="40dp"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="4"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Show Categories switch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Show Categories"
                            android:textSize="15sp"
                            android:textColor="@color/posterita_ink" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_categories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Show Product Images switch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Show Product Images"
                            android:textSize="15sp"
                            android:textColor="@color/posterita_ink" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_product_images"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Show Product Price switch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Show Product Price"
                            android:textSize="15sp"
                            android:textColor="@color/posterita_ink" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_product_price"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Business Type toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Business Type"
                                android:textSize="15sp"
                                android:textColor="@color/posterita_ink" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Restaurant shows Dine-in / Take-away"
                                android:textSize="12sp"
                                android:textColor="@color/posterita_muted" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/btn_retail"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="  Retail  "
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn"
                                android:layout_marginEnd="4dp" />

                            <TextView
                                android:id="@+id/btn_restaurant"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:gravity="center"
                                android:text="  Restaurant  "
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@drawable/stroke_btn" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ======= SECURITY SECTION ======= -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECURITY"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp" />

                    <!-- Require removal note -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Require reason for cart item removal"
                            android:textSize="15sp"
                            android:textColor="@color/posterita_ink" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_require_removal_note"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Require supervisor PIN -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Require supervisor PIN for removal"
                            android:textSize="15sp"
                            android:textColor="@color/posterita_ink" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_require_removal_pin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <!-- Require customer before checkout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Require customer before checkout"
                            android:textSize="15sp"
                            android:textColor="@color/posterita_ink" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_require_customer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ======= QR ENROLLMENT CODE SECTION ======= -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_qr_enrollment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QR ENROLLMENT CODE"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp"
                        android:layout_gravity="start" />

                    <ImageView
                        android:id="@+id/iv_qr_code"
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_marginBottom="8dp"
                        android:contentDescription="QR enrollment code"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="This QR code is used to enroll devices to this terminal"
                        android:textSize="12sp"
                        android:textColor="@color/posterita_muted"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_export_pdf"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Export PDF"
                        style="@style/Widget.Posterita.Button.Outlined" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Note about restart -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Changes will take effect when you return to the product screen."
                android:textSize="12sp"
                android:textColor="@color/posterita_muted"
                android:gravity="center"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:id="@+id/layout_bottom_buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="16dp"
        android:background="@color/posterita_paper"
        android:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Delete"
            android:visibility="gone"
            style="@style/Widget.Posterita.Button.Danger" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            style="@style/Widget.Posterita.Button.Primary" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
