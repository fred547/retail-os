<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/textTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Full Count"
            android:textSize="18sp"
            android:fontFamily="@font/lexend_semibold"
            android:textColor="@color/posterita_ink"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/buttonHelp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_help_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Help"
            android:layout_marginEnd="4dp" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Location selector: Shelf + Height -->
    <LinearLayout
        android:id="@+id/locationBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shelf"
            android:textSize="14sp"
            android:textColor="@color/posterita_muted"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonShelfMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="-"
            android:textSize="18sp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/textShelf"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="20sp"
            android:fontFamily="@font/lexend_bold"
            android:textColor="@color/posterita_primary"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonShelfPlus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:textSize="18sp"
            app:cornerRadius="8dp" />

        <View android:layout_width="16dp" android:layout_height="1dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Height"
            android:textSize="14sp"
            android:textColor="@color/posterita_muted"
            android:layout_marginEnd="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonHeightMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="-"
            android:textSize="18sp"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/textHeight"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="A"
            android:textSize="20sp"
            android:fontFamily="@font/lexend_bold"
            android:textColor="@color/posterita_secondary"
            android:gravity="center" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonHeightPlus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:textSize="18sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- Summary for current location -->
    <TextView
        android:id="@+id/textLocationSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Shelf 1-A: 0 items scanned"
        android:textSize="13sp"
        android:textColor="@color/posterita_muted"
        android:paddingStart="16dp"
        android:paddingTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/locationBar" />

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/actionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/textLocationSummary">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonScan"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="2"
            android:layout_marginEnd="4dp"
            android:text="Scan Barcode"
            android:textAllCaps="false"
            android:textSize="14sp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:backgroundTint="@color/posterita_primary"
            app:cornerRadius="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonAddUnknown"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="+1 Unknown"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:backgroundTint="#F59E0B"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Section header -->
    <TextView
        android:id="@+id/textScansHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scans at this location"
        android:textSize="14sp"
        android:fontFamily="@font/lexend_medium"
        android:textColor="@color/posterita_muted"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/actionRow" />

    <!-- Scans list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerScans"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/textScansHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/textScansHeader"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No scans at this location" android:textSize="16sp" android:textColor="@color/posterita_muted" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Scan a barcode or tap +1 Unknown" android:textSize="13sp" android:textColor="@color/posterita_muted"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Floating sync badge -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonSync"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:text="Sync"
        android:textAllCaps="false"
        app:icon="@drawable/ic_check_circle"
        app:backgroundTint="@color/posterita_secondary"
        app:cornerRadius="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
