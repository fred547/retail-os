<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/consthole"
    android:layout_height="match_parent"
    tools:context=".Activities.SelectUserLoginActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/white"
            android:textAlignment="center"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

            <TextView
                android:id="@+id/toolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Select User"
                android:textColor="@color/black"
                android:textSize="@dimen/_17ssp"
                android:fontFamily="@font/lexend_medium" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ====== PHASE 1: USER SELECTION ====== -->
    <FrameLayout
        android:id="@+id/layout_phase_user_select"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_users"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:clipToPadding="false" />

    </FrameLayout>

    <!-- ====== PHASE 2: PIN ENTRY ====== -->
    <ScrollView
        android:id="@+id/layout_phase_pin"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Selected user display -->
            <TextView
                android:id="@+id/text_selected_user_initial"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/btn_rounded"
                android:gravity="center"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/text_selected_user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/lexend_medium"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_selected_user_initial" />

            <TextView
                android:id="@+id/text_change_user"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Change user"
                android:textColor="#1976D2"
                android:textSize="13sp"
                android:layout_marginTop="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text_selected_user_name" />

            <!-- PIN label -->
            <TextView
                android:id="@+id/txt_pin_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter PIN"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_marginTop="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_change_user" />

            <!-- PIN boxes -->
            <LinearLayout
                android:id="@+id/layout_pin_boxes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txt_pin_label">

                <TextView
                    android:id="@+id/pin_box_1"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_outline_rounded"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pin_box_2"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_outline_rounded"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pin_box_3"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_outline_rounded"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pin_box_4"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_outline_rounded"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pin_box_5"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/btn_outline_rounded"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/pin_box_6"
                    android:layout_width="44dp"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_outline_rounded"
                    android:gravity="center"
                    android:textSize="24sp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Demo PIN hint (only visible for demo account) -->
            <TextView
                android:id="@+id/text_demo_pin_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demo PIN: 000000"
                android:textColor="#999999"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_pin_boxes" />

            <!-- Forgot PIN (only visible for owner) -->
            <TextView
                android:id="@+id/text_forgot_pin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forgot PIN?"
                android:textColor="#1976D2"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_demo_pin_hint" />

            <!-- Biometric button -->
            <ImageButton
                android:id="@+id/btn_biometric"
                android:layout_width="@dimen/_48sdp"
                android:layout_height="@dimen/_48sdp"
                android:layout_marginTop="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Biometric Login"
                android:scaleType="centerInside"
                android:src="@drawable/ic_fingerprint"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/text_forgot_pin"
                app:tint="@color/txt_color" />

            <!-- PIN Numpad -->
            <GridLayout
                android:id="@+id/grid_pin_numpad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="50dp"
                android:layout_marginTop="16dp"
                android:columnCount="3"
                android:rowCount="4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/btn_biometric">

                <Button
                    android:id="@+id/pin_btn_1"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="1"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_2"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="2"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_3"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="3"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_4"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="4"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_5"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="5"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_6"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="6"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_7"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="7"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_8"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="8"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_9"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="9"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_clear"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="C"
                    android:textColor="#E53935"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/pin_btn_0"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="0"
                    android:textColor="@color/black"
                    android:textSize="22sp" />

                <Button
                    android:id="@+id/pin_btn_backspace"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="3dp"
                    android:background="@drawable/stroke_btn"
                    android:text="⌫"
                    android:textColor="#E53935"
                    android:textSize="20sp" />
            </GridLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Hidden views kept for binding compatibility -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/textinput_layout_user"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/autoComplete_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/edtPsd"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtPsdInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberPassword"
            android:textColor="@color/black" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Hidden done button kept for binding compatibility -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/button_done"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
