<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg"
    tools:context=".Activities.ReceiptActivity">

    <!-- Toolbar: back + Receipt title -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/posterita_paper"
        app:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back">

            <TextView
                android:id="@+id/text_view_order_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:layout_marginStart="4dp"
                android:text="Receipt"
                style="@style/TextAppearance.Posterita.Heading" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable receipt content -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout"
        app:layout_constraintBottom_toTopOf="@+id/layoutButtons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Success indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingBottom="16dp">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp">

                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_success_card" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="Sale complete"
                        app:tint="@color/posterita_secondary" />
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Sale Complete"
                    style="@style/TextAppearance.Posterita.Heading"
                    android:textColor="@color/posterita_secondary" />

                <!-- Change Due -->
                <TextView
                    android:id="@+id/txtrecipiy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Change Due"
                    style="@style/TextAppearance.Posterita.Tiny"
                    android:textColor="@color/posterita_muted" />

                <TextView
                    android:id="@+id/text_view_change_due"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Rs 0.00"
                    android:textSize="32sp"
                    android:fontFamily="@font/lexend_medium"
                    android:textColor="@color/posterita_secondary" />

                <TextView
                    android:id="@+id/text_view_tips_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    style="@style/TextAppearance.Posterita.Micro"
                    android:textColor="@color/posterita_purple"
                    android:visibility="gone"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Receipt card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Order Info -->
                    <TextView
                        android:id="@+id/text_view_date"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Posterita.Tiny"
                        android:textColor="@color/posterita_muted"
                        android:gravity="center"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/text_view_customer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Posterita.Tiny"
                        android:textColor="@color/posterita_muted"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/text_view_sales_rep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Posterita.Tiny"
                        android:textColor="@color/posterita_muted"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />

                    <!-- Separator before items -->
                    <View
                        android:id="@+id/separator_items_top"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/posterita_line"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <!-- Items Header -->
                    <LinearLayout
                        android:id="@+id/header_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Item"
                            style="@style/TextAppearance.Posterita.Micro"
                            android:textColor="@color/posterita_muted" />

                        <TextView
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:text="Qty"
                            style="@style/TextAppearance.Posterita.Micro"
                            android:textColor="@color/posterita_muted"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:text="Amount"
                            style="@style/TextAppearance.Posterita.Micro"
                            android:textColor="@color/posterita_muted"
                            android:gravity="end" />
                    </LinearLayout>

                    <!-- Order Items Container -->
                    <LinearLayout
                        android:id="@+id/layout_order_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- Separator after items -->
                    <View
                        android:id="@+id/separator_items_bottom"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/posterita_line"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <!-- Totals Section -->
                    <LinearLayout
                        android:id="@+id/layout_totals"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <!-- Order Note -->
                    <TextView
                        android:id="@+id/text_view_order_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.Posterita.Tiny"
                        android:textColor="@color/posterita_muted"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />

                    <!-- Payment Section -->
                    <View
                        android:id="@+id/separator_payment"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/posterita_line"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layout_payments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Bottom padding -->
            <TextView
                android:id="@+id/txtpad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom buttons: VOID | PRINT | NEW SALE -->
    <LinearLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="14dp"
        android:background="@color/posterita_paper"
        android:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_void_order"
            style="@style/Widget.Posterita.Button.Danger"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Void" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_print_order"
            style="@style/Widget.Posterita.Button.Outlined"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Print" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_new_sale"
            style="@style/Widget.Posterita.Button.Pay"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="2"
            android:text="New Sale" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
