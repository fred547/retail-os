<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/space_xs"
    android:layout_marginEnd="@dimen/space_xs"
    android:layout_marginTop="@dimen/space_xs"
    android:layout_marginBottom="@dimen/space_xs"
    app:cardCornerRadius="@dimen/radius_md"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/posterita_line"
    app:cardBackgroundColor="@color/posterita_paper">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header: Table name + Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txt_table_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Table 1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_ink" />

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="20dp"
                android:gravity="center"
                android:text="NEW"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/btn_rounded"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txt_elapsed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5m"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_orange"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txt_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="14:30"
                android:textSize="12sp"
                android:textColor="@color/posterita_muted" />
        </LinearLayout>

        <!-- Order description / items summary -->
        <TextView
            android:id="@+id/txt_items_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="2x Burger, 1x Fries"
            android:textSize="13sp"
            android:textColor="@color/posterita_muted"
            android:maxLines="3"
            android:ellipsize="end" />

        <!-- Note banner (if order has a note) -->
        <TextView
            android:id="@+id/txt_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@color/posterita_warning_light"
            android:textSize="12sp"
            android:textColor="@color/posterita_warning"
            android:visibility="gone"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Total -->
        <TextView
            android:id="@+id/txt_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Total: Rs 450.00"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/posterita_primary" />

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/btn_add_note"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="NOTE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_muted"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/btn_recall"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="RECALL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_muted"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/btn_print_bill"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="BILL"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_muted"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/btn_split"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="SPLIT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_purple"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/btn_delete"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="DELETE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/posterita_error"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/btn_complete"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="PAY"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/btn_rounded" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>