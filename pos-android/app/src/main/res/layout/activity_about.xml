<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/posterita_paper"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/button_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_drawer"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/posterita_ink"
            android:contentDescription="Menu" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="About"
            style="@style/TextAppearance.Posterita.Heading" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Hidden toolbar for binding compat -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp"
            android:gravity="center_horizontal">

            <!-- Logo -->
            <ImageView
                android:id="@+id/image_logo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_splash"
                android:contentDescription="Posterita logo" />

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Posterita"
                style="@style/TextAppearance.Posterita.Heading"
                android:textColor="@color/posterita_ink" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Retail OS"
                style="@style/TextAppearance.Posterita.Body.Muted" />

            <!-- Current Session Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT SESSION"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp" />

                    <!-- Brand -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Brand"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/tv_brand_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="My Brand" />
                    </LinearLayout>

                    <!-- Store -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Store"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/tv_store_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="Main Store" />
                    </LinearLayout>

                    <!-- Terminal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Terminal"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/tv_terminal_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="Terminal 1" />
                    </LinearLayout>

                    <!-- User -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="User"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/tv_user_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="John Doe" />
                    </LinearLayout>

                    <!-- Currency -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Currency"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/tv_currency_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="MUR" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Version Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VERSION"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="App Version"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/text_view_version_name_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="1.0.0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Build"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/text_view_version_code_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="18" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Device ID"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/text_view_device_id_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_muted"
                            tools:text="abc123" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Support Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/posterita_line"
                app:cardBackgroundColor="@color/posterita_paper">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SUPPORT"
                        style="@style/TextAppearance.Posterita.Label"
                        android:textColor="@color/posterita_muted"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Website"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/text_view_website_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="posterita.com"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Email"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_ink" />

                        <TextView
                            android:id="@+id/text_view_email_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="support@posterita.com"
                            style="@style/TextAppearance.Posterita.Body"
                            android:textColor="@color/posterita_primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
