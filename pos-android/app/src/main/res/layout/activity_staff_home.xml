<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg">

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/buttonBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Staff"
            android:textSize="20sp"
            android:fontFamily="@font/lexend_semibold"
            android:textColor="@color/posterita_ink"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/buttonHelp"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_help_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Help"
            android:layout_marginEnd="4dp" />

        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Summary cards -->
    <LinearLayout
        android:id="@+id/summaryCards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/posterita_line">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:id="@+id/textShiftStatus" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="--" android:textSize="18sp"
                    android:fontFamily="@font/lexend_bold" android:textColor="@color/posterita_primary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Shift" android:textSize="12sp" android:textColor="@color/posterita_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/posterita_line">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:id="@+id/textHoursToday" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0.0" android:textSize="18sp"
                    android:fontFamily="@font/lexend_bold" android:textColor="#0891B2" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hours" android:textSize="12sp" android:textColor="@color/posterita_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/posterita_line">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center" android:padding="12dp">
                <TextView android:id="@+id/textOrdersToday" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="0" android:textSize="18sp"
                    android:fontFamily="@font/lexend_bold" android:textColor="@color/posterita_secondary" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Orders" android:textSize="12sp" android:textColor="@color/posterita_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Clock in/out button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonClockInOut"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:text="Clock In"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="#10B981"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_check_circle"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/summaryCards" />

    <!-- Action buttons row -->
    <LinearLayout
        android:id="@+id/actionRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/buttonClockInOut">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonInventoryCount"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Count Stock"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonStockCheck"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Stock Check"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonViewOrders"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Orders"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonRoster"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Roster"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="10dp" />
    </LinearLayout>

    <!-- My Upcoming Shifts card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardUpcomingShifts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/posterita_line"
        app:layout_constraintTop_toBottomOf="@id/actionRow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Upcoming Shifts"
                android:textSize="13sp"
                android:fontFamily="@font/lexend_medium"
                android:textColor="@color/posterita_ink" />

            <LinearLayout
                android:id="@+id/layoutUpcomingList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Section header -->
    <TextView
        android:id="@+id/textShiftsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recent Shifts"
        android:textSize="14sp"
        android:fontFamily="@font/lexend_medium"
        android:textColor="@color/posterita_muted"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardUpcomingShifts" />

    <!-- Shifts list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerShifts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/textShiftsHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmptyShifts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/textShiftsHeader"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No shifts recorded yet" android:textSize="16sp" android:textColor="@color/posterita_muted" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Clock in to start your shift" android:textSize="13sp" android:textColor="@color/posterita_muted"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
