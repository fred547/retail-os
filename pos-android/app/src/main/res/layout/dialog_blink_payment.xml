<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Amount Due"
        android:textSize="14sp"
        android:textColor="@color/posterita_muted"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_amount_due"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="28sp"
        android:textColor="@color/posterita_ink"
        android:fontFamily="@font/lexend_medium"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp" />

    <!-- QR Code Image -->
    <ImageView
        android:id="@+id/image_qr_code"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:scaleType="fitCenter"
        android:visibility="gone" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/progress_loading"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <!-- Status text -->
    <TextView
        android:id="@+id/text_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/posterita_muted"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:text="Generating QR Code..." />

    <TextView
        android:id="@+id/text_instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/posterita_muted"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:text="Scan the QR code with your Blink app to complete the payment"
        android:visibility="gone" />

</LinearLayout>
