<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/button_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Printer"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Printer Name -->

            <!--<TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Printer Name"
                android:textSize="@dimen/_14sdp"
                android:layout_marginTop="8dp" />-->

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Printer Name">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_printer_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/black" />
            </com.google.android.material.textfield.TextInputLayout>

            <!--<TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Printer Name"
                android:textSize="@dimen/_14sdp"
                android:layout_marginTop="8dp" />

            <EditText
                android:id="@+id/edit_text_printer_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Printer Name"
                android:textColor="@android:color/black" />-->

            <!--<View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:background="#CCCCCC"/>-->

            <!-- Interface Spinner -->
            <!--<TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Interface"
                android:textSize="@dimen/_14sdp"
                android:layout_marginTop="8dp" />-->

            <!--<Spinner
                android:id="@+id/interface_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />-->

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/text_input_interface_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:layout_marginTop="16dp"
                android:hint="Select Interface"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                >

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/interface_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Network Layout -->
            <LinearLayout
                android:id="@+id/network_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!--<TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Printer IP Address"
                    android:textSize="@dimen/_14sdp"
                    android:layout_marginTop="8dp" />

                <EditText
                    android:id="@+id/printer_ip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter IP Address"
                    android:textColor="@android:color/black" />-->
                <!--<TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Printer IP Address"
                    android:textSize="@dimen/_14sdp"
                    android:layout_marginTop="8dp" />-->



                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/text_input_printer_ip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter IP Address">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/printer_ip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/black" />
                </com.google.android.material.textfield.TextInputLayout>



            </LinearLayout>

            <!-- USB Devices Layout -->
            <LinearLayout
                android:id="@+id/usb_devices_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="USB Devices"
                    android:layout_marginTop="8dp" />

                <!--<Spinner
                    android:id="@+id/spinner_usb_devices"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />-->

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/text_input_usb_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="19dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="19dp"
                    android:hint="Select Interface"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                    >
                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/spinner_usb_devices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Bluetooth Layout -->
            <LinearLayout
                android:id="@+id/bluetooth_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!--<TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bluetooth Printer"
                    android:textSize="@dimen/_14sdp"
                    android:layout_marginTop="8dp" />-->

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/text_input_printer_bluetooth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Select Bluetooth Device">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/printer_bluetooth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/black" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/button_scan_bluetooth"
                        android:layout_width="wrap_content"
                        android:layout_height="55dp"
                        android:layout_marginLeft="@dimen/_5sdp"
                        android:background="@drawable/btn_rounded"
                        android:fontFamily="@font/lexend_medium"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_17ssp"
                        android:text="Search"
                        android:layout_marginTop="@dimen/_2sdp"/>
                </LinearLayout>
            </LinearLayout>


            <!-- Bluetooth Layout -->
            <!--<com.google.android.material.card.MaterialCardView
                android:id="@+id/bluetooth_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:visibility="gone"
                app:cardElevation="4dp"
                app:cardCornerRadius="8dp">

