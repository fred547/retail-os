<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg"
    tools:context=".Activities.CartActivity">

    <!-- Top bar: ☰ Cart (consistent with POS) -->
    <LinearLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="@color/posterita_paper"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/button_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:contentDescription="Back"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/posterita_ink" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cart"
            style="@style/TextAppearance.Posterita.Heading" />

        <!-- Connectivity indicator -->
        <View
            android:id="@+id/connectivity_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_internet_dot" />
    </LinearLayout>

    <!-- Hidden toolbar for binding compat -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Customer search bar + clear cart bin -->
    <LinearLayout
        android:id="@+id/layout_customer_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <LinearLayout
            android:id="@+id/layout_customer_bar"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:background="@drawable/bg_search_bar"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search"
                app:tint="@color/posterita_muted" />

            <ImageView
                android:id="@+id/image_view_search_customer"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_user"
                android:contentDescription="Customer"
                app:tint="@color/posterita_muted" />

            <TextView
                android:id="@+id/text_view_customer_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Walk-in customer"
                android:textColor="@color/posterita_muted"
                style="@style/TextAppearance.Posterita.Body" />

            <TextView
                android:id="@+id/text_view_loyalty_points"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                style="@style/TextAppearance.Posterita.Micro"
                android:textColor="@color/posterita_purple"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Hidden for binding compat (clear cart is in MORE menu) -->
        <ImageView
            android:id="@+id/button_clear_cart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Hidden for binding compat -->
    <ImageView
        android:id="@+id/button_more"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Order note banner -->
    <TextView
        android:id="@+id/text_view_order_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/posterita_warning_light"
        android:drawableStart="@android:drawable/ic_dialog_info"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        style="@style/TextAppearance.Posterita.Body.Muted"
        android:textSize="13sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/layout_customer_row" />

    <!-- Kitchen order banner -->
    <TextView
        android:id="@+id/text_view_kitchen_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/posterita_primary_light"
        android:drawableStart="@android:drawable/ic_menu_recent_history"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:text="Kitchen order — receipt only (no kitchen reprint)"
        style="@style/TextAppearance.Posterita.Micro"
        android:textColor="@color/posterita_primary_dark"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/text_view_order_note" />

    <!-- Empty state for cart -->
    <LinearLayout
        android:id="@+id/layout_empty_cart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
        app:layout_constraintTop_toBottomOf="@+id/text_view_kitchen_banner">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:alpha="0.3"
            android:contentDescription="Empty cart"
            android:src="@drawable/ic_shopping_cart"
            app:tint="@color/posterita_muted" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Your cart is empty"
            style="@style/TextAppearance.Posterita.Heading"
            android:textColor="@color/posterita_muted" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Add products to get started"
            style="@style/TextAppearance.Posterita.Body.Muted" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_browse_products"
            style="@style/Widget.Posterita.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:text="Browse Products"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />
    </LinearLayout>

    <!-- Cart items list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_cart_lines"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:clipToPadding="false"
        android:paddingBottom="4dp"
        app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
        app:layout_constraintTop_toBottomOf="@+id/text_view_kitchen_banner" />

    <!-- Totals + Actions bottom panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/posterita_paper"
        android:elevation="4dp"
        android:paddingTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Note + Tips row (tappable inline chips) -->
        <LinearLayout
            android:id="@+id/layout_note_tips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Add note chip -->
            <TextView
                android:id="@+id/chip_note"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp"
                android:text="+ Note"
                android:textColor="@color/posterita_primary"
                style="@style/TextAppearance.Posterita.Micro"
                android:background="@drawable/btn_outline_rounded"
                android:clickable="true"
                android:focusable="true" />

            <!-- Add tips chip -->
            <TextView
                android:id="@+id/chip_tips"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="+ Tips"
                android:textColor="@color/posterita_primary"
                style="@style/TextAppearance.Posterita.Micro"
                android:background="@drawable/btn_outline_rounded"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Sub Total -->
        <TextView
            android:id="@+id/txt_sub_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Sub total"
            style="@style/TextAppearance.Posterita.Body.Muted"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_note_tips" />

        <TextView
            android:id="@+id/text_view_subtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:text="0.00"
            style="@style/TextAppearance.Posterita.Body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layout_note_tips" />

        <!-- Tax Total -->
        <TextView
            android:id="@+id/txt_tex_totoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="6dp"
            android:text="Tax total"
            style="@style/TextAppearance.Posterita.Body.Muted"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_sub_total" />

        <TextView
            android:id="@+id/text_view_tax_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="20dp"
            android:text="0.00"
            style="@style/TextAppearance.Posterita.Body"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_sub_total" />

        <!-- Discount (hidden by default) -->
        <TextView
            android:id="@+id/txt_discount_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="6dp"
            android:text="Discount"
            style="@style/TextAppearance.Posterita.Body"
            android:textColor="@color/posterita_error"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_tex_totoal" />

        <TextView
            android:id="@+id/text_view_discount_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="20dp"
            android:text="-0.00"
            style="@style/TextAppearance.Posterita.Body"
            android:textColor="@color/posterita_error"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_tex_totoal" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_before_total"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="txt_tex_totoal,text_view_tax_total,txt_discount_total,text_view_discount_total" />

        <!-- Divider before total -->
        <View
            android:id="@+id/dividerTotal"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:background="@color/posterita_line"
            app:layout_constraintTop_toBottomOf="@id/barrier_before_total" />

        <!-- Grand Total (tappable for discount) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:text="Total"
            style="@style/TextAppearance.Posterita.Heading"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerTotal" />

        <TextView
            android:id="@+id/text_view_grand_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="20dp"
            android:text="0.00"
            style="@style/TextAppearance.Posterita.Heading"
            android:textColor="@color/posterita_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dividerTotal" />

        <!-- Bottom buttons: MORE | HOLD | PAY -->
        <LinearLayout
            android:id="@+id/layout_bottom_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:paddingTop="14dp"
            app:layout_constraintTop_toBottomOf="@+id/text_view_grand_total"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Hidden buttons for binding compat -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_note"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_discount"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_bottom"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_add_customer"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Hidden for binding compat -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_bar"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Hidden for binding compat -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_hold_order"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_cart"
                style="@style/Widget.Posterita.Button.Outlined"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="MORE" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_pay_order"
                style="@style/Widget.Posterita.Button.Pay"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="2"
                android:text="PAY" />

            <TextView
                android:id="@+id/button_pay_text"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Hidden views for binding compat -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/button_coupon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/button_more_options"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
