<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/posterita_bg"
    android:id="@+id/conwhole"
    tools:context=".Activities.CloseTillPopUpActivity">
    <ImageView
        android:id="@+id/back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/app_name"
        android:src="@drawable/ic_back_cart"
        android:layout_marginStart="@dimen/_15sdp"
        app:layout_constraintTop_toTopOf="@id/txt_order"
        app:layout_constraintBottom_toBottomOf="@id/txt_order"
        app:layout_constraintStart_toStartOf="parent"
        />
    <TextView
        android:id="@+id/txt_order"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Close Till"
        android:textColor="@color/black"
        android:textSize="20sp"
        android:fontFamily="@font/lexend_medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/_12sdp"/>
    <!-- Cash Amount with +/- buttons -->
    <LinearLayout
        android:id="@+id/cashRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="@dimen/_15sdp"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_15sdp"
        app:layout_constraintTop_toBottomOf="@id/txt_order">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCashMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="−"
            android:textSize="22sp"
            android:textColor="@color/posterita_ink"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/posterita_line" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:id="@+id/edtPsd"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_height="wrap_content"
            android:hint="Cash Amount"
            app:shapeAppearance="@style/Rounded">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:id="@+id/edtPsdInput"
                android:textColor="@color/black"
                android:inputType="numberDecimal"
                android:layout_height="wrap_content" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCashPlus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="22sp"
            android:textColor="@color/posterita_ink"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/posterita_line" />
    </LinearLayout>

    <!-- Card Amount with +/- buttons -->
    <LinearLayout
        android:id="@+id/cardRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="@dimen/_15sdp"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_marginTop="@dimen/_15sdp"
        app:layout_constraintTop_toBottomOf="@id/cashRow">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCardMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="−"
            android:textSize="22sp"
            android:textColor="@color/posterita_ink"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/posterita_line" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:id="@+id/edtcard"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_height="wrap_content"
            android:hint="Card Amount"
            app:shapeAppearance="@style/Rounded">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:id="@+id/edtcrdInput"
                android:textColor="@color/black"
                android:inputType="numberDecimal"
                android:layout_height="wrap_content" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCardPlus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="+"
            android:textSize="22sp"
            android:textColor="@color/posterita_ink"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            app:cornerRadius="12dp"
            app:strokeColor="@color/posterita_line" />
    </LinearLayout>
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="0dp"
        android:id="@+id/edtForexCurrencyLayout"
        android:layout_marginStart="@dimen/_15sdp"
        android:layout_marginEnd="4dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/cardRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/edtForexAmtLayout"
        android:layout_marginTop="@dimen/_15sdp"
        android:hint="Forex Currency"
        app:shapeAppearance="@style/Rounded">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:id="@+id/edtForexCurrencyInput"
            android:textColor="@color/black"
            android:inputType="textCapCharacters"
            android:maxLength="3"
            android:layout_height="wrap_content" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
        android:layout_width="0dp"
        android:id="@+id/edtForexAmtLayout"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="@dimen/_15sdp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/cardRow"
        app:layout_constraintStart_toEndOf="@id/edtForexCurrencyLayout"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/_15sdp"
        android:hint="Forex Amount"
        app:shapeAppearance="@style/Rounded">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:id="@+id/edtForexAmtInput"
            android:textColor="@color/black"
            android:inputType="numberDecimal"
            android:layout_height="wrap_content" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_close_till"
        style="@style/Widget.Posterita.Button.Primary"
        android:layout_width="@dimen/_100sdp"
        android:layout_height="48dp"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginEnd="@dimen/_15sdp"
        android:text="Close"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtForexAmtLayout" />
    <com.google.android.material.button.MaterialButton
        android:id="@+id/constCancel"
        style="@style/Widget.Posterita.Button.Outlined"
        android:layout_width="@dimen/_100sdp"
        android:layout_height="48dp"
        android:layout_marginTop="@dimen/_20sdp"
        android:layout_marginStart="@dimen/_15sdp"
        android:text="Cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/edtForexAmtLayout" />

</androidx.constraintlayout.widget.ConstraintLayout>