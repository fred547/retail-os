<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/posterita_paper"
    app:strokeWidth="1dp"
    app:strokeColor="#E8E8E8">

    <TextView
        android:id="@+id/id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <!-- Row 1: Order number · time  |  Status badge  |  Amount -->

        <TextView
            android:id="@+id/text_view_documentno"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/posterita_ink"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            tools:text="#0000130 · 14:32"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/text_view_status"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintHorizontal_bias="0" />

        <TextView
            android:id="@+id/text_view_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            tools:text="PAID"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/text_view_documentno" />

        <!-- Row 2: Customer  |  Payment type · Amount -->

        <ImageView
            android:id="@+id/icon_customer"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="10dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/posterita_muted"
            android:contentDescription="Customer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_view_documentno" />

        <TextView
            android:id="@+id/text_view_customer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginTop="10dp"
            android:textColor="@color/posterita_muted"
            android:textSize="13sp"
            android:singleLine="true"
            android:ellipsize="end"
            tools:text="Walk-in Customer"
            app:layout_constraintStart_toEndOf="@id/icon_customer"
            app:layout_constraintEnd_toStartOf="@id/text_view_amount"
            app:layout_constraintTop_toBottomOf="@id/text_view_documentno" />

        <TextView
            android:id="@+id/text_view_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/posterita_ink"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="MUR 130.00"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_view_status" />

        <!-- Row 3: Payment type + items count  |  Sync status -->

        <TextView
            android:id="@+id/text_view_payment_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/posterita_muted"
            android:textSize="12sp"
            tools:text="Cash"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_view_customer"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/text_view_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:textColor="@color/posterita_muted"
            android:textSize="12sp"
            tools:text="14:32"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_view_customer"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/icon_sync"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="6dp"
            android:layout_marginStart="12dp"
            android:src="@android:drawable/ic_popup_sync"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintStart_toEndOf="@id/text_view_payment_type"
            app:layout_constraintTop_toBottomOf="@id/text_view_customer"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/text_view_sync_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="3dp"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="Synced"
            tools:visibility="visible"
            app:layout_constraintStart_toEndOf="@id/icon_sync"
            app:layout_constraintTop_toBottomOf="@id/text_view_customer"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/text_view_items_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/posterita_muted"
            android:textSize="12sp"
            tools:text="3 items"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_view_amount"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
