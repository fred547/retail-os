<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <!-- Success icon -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="Setup Complete"
            app:tint="@color/posterita_secondary" />

        <TextView
            android:id="@+id/tvCompleteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="You're all set!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/posterita_ink" />

        <TextView
            android:id="@+id/tvCompleteSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Your account has been created. Here's what we set up for you."
            android:textSize="14sp"
            android:textColor="@color/posterita_muted" />

        <!-- Email verification banner -->
        <TextView
            android:id="@+id/tvVerificationBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:padding="12dp"
            android:background="@color/posterita_primary_light"
            android:textColor="@color/posterita_primary"
            android:textSize="13sp"
            android:drawablePadding="8dp"
            android:visibility="gone" />

        <!-- Summary card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/posterita_line"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/layoutSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="You can manage products, stores, and users from the Settings menu anytime."
            android:textSize="13sp"
            android:textColor="@color/posterita_muted" />

    </LinearLayout>
</ScrollView>
