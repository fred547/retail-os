<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_empty_state"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:visibility="gone">

    <ImageView
        android:id="@+id/image_empty_icon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:alpha="0.4"
        android:contentDescription="No items"
        android:src="@drawable/ic_product_placeholder" />

    <TextView
        android:id="@+id/text_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="No items found"
        android:textColor="#999999"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/text_empty_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Items will appear here"
        android:textColor="#BBBBBB"
        android:textSize="14sp" />

</LinearLayout>
