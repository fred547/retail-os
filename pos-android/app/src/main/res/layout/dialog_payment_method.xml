<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Amount Due"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center" />

        <TextView
            android:id="@+id/text_amount_due"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/black"
            android:fontFamily="@font/lexend_medium"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp" />

        <!-- Row 1: Cash | Card -->
        <LinearLayout
            android:id="@+id/row_cash_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/btn_cash"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="💵  Cash"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_card"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="💳  Card"
                android:textColor="@color/black"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Row 2: On Credit | Check -->
        <LinearLayout
            android:id="@+id/row_credit_check"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/btn_credit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="📋  On Credit"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_check"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="📝  Check"
                android:textColor="@color/black"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Row 3: Peach | Juice -->
        <LinearLayout
            android:id="@+id/row_peach_juice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/btn_peach"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="🍑  Peach"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_juice"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="🧃  Juice"
                android:textColor="@color/black"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Row 4: Blink | Online -->
        <LinearLayout
            android:id="@+id/row_blink_online"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/btn_blink"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="⚡  Blink"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_online"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="🌐  Online"
                android:textColor="@color/black"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Row 5: Split/Mix | Forex -->
        <LinearLayout
            android:id="@+id/row_mixed_forex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/btn_mixed"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="🔀  Split / Mix"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/btn_forex"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="💱  Forex Cash"
                android:textColor="@color/black"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Tips Section -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="💡 Tips"
                android:textSize="15sp"
                android:textColor="@color/black" />

            <EditText
                android:id="@+id/edit_tips_amount"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:inputType="numberDecimal"
                android:textSize="15sp"
                android:textColor="@color/black"
                android:padding="8dp"
                android:gravity="end|center_vertical"
                android:background="@drawable/btn_outline_rounded"
                android:hint="0.00" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
