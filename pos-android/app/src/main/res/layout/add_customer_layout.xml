<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:background="@drawable/dialog_bg"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/_15sdp">

            <TextView
                android:id="@+id/txt_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Add Customer"
                android:textColor="@color/posterita_primary"
                android:fontFamily="@font/lexend_medium"
                android:textSize="20sp"
                android:layout_marginTop="@dimen/_15sdp" />

            <!-- Country code + phone number display -->
            <LinearLayout
                android:id="@+id/layout_phone_display"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_12sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txt_country_code"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="+230"
                    android:textSize="18sp"
                    android:textColor="@color/posterita_ink"
                    android:fontFamily="@font/lexend_medium"
                    android:background="@drawable/btn_outline_rounded"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <!-- Phone number display as styled text -->
                <TextView
                    android:id="@+id/txt_phone_number"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:gravity="center"
                    android:textSize="22sp"
                    android:textColor="@color/posterita_ink"
                    android:fontFamily="@font/lexend_medium"
                    android:letterSpacing="0.3"
                    android:background="@drawable/btn_outline_rounded"
                    android:hint="_ _ _ _ _ _ _ _"
                    android:textColorHint="@color/posterita_muted" />

                <!-- Hidden view for compat -->
                <TextView
                    android:id="@+id/txt_phone_display"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Digit counter + Validation on same line -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/txt_validation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/posterita_error"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txt_digit_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/posterita_muted"
                    android:textSize="12sp"
                    android:text="0 / 8 digits" />
            </LinearLayout>

            <!-- Numpad -->
            <GridLayout
                android:id="@+id/grid_numpad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:columnCount="3"
                android:rowCount="4">

                <Button
                    android:id="@+id/btn_1"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="1"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_2"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="2"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_3"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="3"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_4"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="4"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_5"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="5"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_6"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="6"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_7"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="7"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_8"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="8"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_9"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="9"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_details"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="+"
                    android:textColor="@color/posterita_muted"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btn_0"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:text="0"
                    android:textColor="@color/posterita_ink"
                    android:textSize="20sp" />

                <Button
                    android:id="@+id/btn_backspace"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:background="@drawable/stroke_btn"
                    android:textColor="@color/posterita_error"
                    android:textSize="18sp" />
            </GridLayout>

            <!-- Create by Name button -->
            <TextView
                android:id="@+id/btn_create_by_name"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/stroke_btn"
                android:gravity="center"
                android:text="Or create by name only"
                android:textColor="@color/posterita_muted"
                android:textSize="14sp" />

            <!-- Extra details section (hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_extra_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Name (optional)"
                    app:shapeAppearance="@style/Rounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/text_customer_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/posterita_ink" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:hint="Email (optional)"
                    app:shapeAppearance="@style/Rounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/text_email_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/posterita_ink" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_8sdp"
                    android:hint="Address (optional)"
                    app:shapeAppearance="@style/Rounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/text_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:textColor="@color/posterita_ink" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_12sdp"
                android:gravity="center">

                <!-- Cancel hidden — tapping outside dismisses -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_cancel"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <!-- Hidden skip for binding compat -->
                <TextView
                    android:id="@+id/button_skip"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <!-- Dynamic: shows "Skip" when empty, "Save" when full -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/button_save"
                    style="@style/Widget.Posterita.Button.Pay"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Skip" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
