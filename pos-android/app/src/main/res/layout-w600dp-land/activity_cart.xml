<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".ui.activity.CartActivity">

    <ImageView
        android:id="@+id/button_back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_back_cart"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="@dimen/_15sdp"
        android:layout_marginStart="@dimen/_15sdp"/>

    <LinearLayout
        android:id="@+id/layout_customer_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/image_view_search_customer"
        app:layout_constraintEnd_toStartOf="@+id/image_view_search_customer"
        app:layout_constraintStart_toEndOf="@+id/button_back"
        app:layout_constraintTop_toTopOf="@+id/image_view_search_customer">

        <TextView
            android:id="@+id/text_view_customer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="@dimen/_13sdp" />

        <TextView
            android:id="@+id/text_view_loyalty_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="@dimen/_10sdp"
            android:textColor="@color/colorAccent"
            android:visibility="gone" />

    </LinearLayout>

    <ImageView
        android:id="@+id/image_view_search_customer"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_user"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="@+id/button_more"
        app:layout_constraintEnd_toStartOf="@+id/button_more"
        app:layout_constraintTop_toTopOf="@+id/button_more" />

    <ImageView
        android:id="@+id/button_more"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_39sdp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="19dp"
        android:src="@drawable/ic_more_vert"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/txt_color"
        android:visibility="gone" />

    <!-- Order note banner -->
    <TextView
        android:id="@+id/text_view_order_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF9C4"
        android:drawableStart="@android:drawable/ic_dialog_info"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textColor="#795548"
        android:textSize="11sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/image_view_search_customer" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_cart_lines"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/text_view_order_note"
        app:layout_constraintBottom_toTopOf="@id/constraintLayout"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_4sdp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_20sdp"
        android:background="@color/white">

        <TextView
            android:id="@+id/txt_sub_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="@color/black"
            android:text="Sub total"
            app:layout_constraintBottom_toTopOf="@id/txt_tex_totoal"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_5sdp"/>

        <TextView
            android:id="@+id/txt_tex_totoal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="@color/black"
            android:text="Tax total"
            app:layout_constraintBottom_toTopOf="@id/text_view_grand_total"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_5sdp"/>

        <TextView
            android:id="@+id/text_view_subtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="@color/black"
            android:text="0.00"
            app:layout_constraintBottom_toTopOf="@id/txt_tex_totoal"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_5sdp"/>

        <TextView
            android:id="@+id/text_view_tax_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="@color/black"
            android:text="00.00"
            app:layout_constraintBottom_toTopOf="@id/txt_discount_total"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_5sdp"/>

        <TextView
            android:id="@+id/txt_discount_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="#E53935"
            android:text="Discount"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/text_view_grand_total"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_5sdp"/>

        <TextView
            android:id="@+id/text_view_discount_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/_10ssp"
            android:textColor="#E53935"
            android:text="-0.00"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/text_view_grand_total"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="@dimen/_15sdp"
            android:layout_marginBottom="@dimen/_5sdp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total"
            android:textColor="@color/black"
            android:fontFamily="@font/lexend_medium"
            app:layout_constraintBottom_toTopOf="@+id/layout_bottom_buttons"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginBottom="@dimen/_5sdp"
            android:layout_marginStart="@dimen/_15sdp"
            android:textSize="@dimen/_12ssp"/>

        <TextView
            android:id="@+id/text_view_grand_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RS"
            android:textColor="@color/black"
            android:fontFamily="@font/lexend_medium"
            app:layout_constraintBottom_toTopOf="@+id/layout_bottom_buttons"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="@dimen/_5sdp"
            android:layout_marginEnd="@dimen/_15sdp"
            android:textSize="@dimen/_12ssp"/>

        <!-- Bottom button bar (matching product screen layout) -->
        <LinearLayout
            android:id="@+id/layout_bottom_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/_6sdp"
            android:paddingEnd="@dimen/_6sdp"
            android:paddingBottom="@dimen/_6sdp"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Row 1: CLEAR, DISCOUNT, MORE - each 1/3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/button_clear_cart"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_22sdp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="CLEAR"
                    android:textColor="#E53935"
                    android:textSize="@dimen/_9ssp"
                    android:textStyle="bold"
                    android:background="@drawable/stroke_btn" />

                <TextView
                    android:id="@+id/button_discount"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_22sdp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="DISCOUNT"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_9ssp"
                    android:textStyle="bold"
                    android:background="@drawable/stroke_btn" />

                <TextView
                    android:id="@+id/button_more_bottom"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_22sdp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:gravity="center"
                    android:text="MORE"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_9ssp"
                    android:textStyle="bold"
                    android:background="@drawable/stroke_btn" />
            </LinearLayout>

            <!-- Row 2: HOLD (1/4), CUST (1/4), PAY (1/2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/button_hold_order"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_28sdp"
                    android:layout_weight="1"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="HOLD"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_9ssp"
                    android:textStyle="bold"
                    android:background="@drawable/stroke_btn" />

                <TextView
                    android:id="@+id/button_add_customer"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_28sdp"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:gravity="center"
                    android:text="CUST"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_9ssp"
                    android:textStyle="bold"
                    android:background="@drawable/stroke_btn" />

                <LinearLayout
                    android:id="@+id/button_pay_order"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_28sdp"
                    android:layout_weight="2"
                    android:layout_marginStart="3dp"
                    android:background="@drawable/btn_rounded"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/button_pay_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_medium"
                        android:text="PAY"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend_medium"
                        android:text=" >"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_14ssp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Hidden views for binding compatibility -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/button_coupon"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/button_more_options"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
