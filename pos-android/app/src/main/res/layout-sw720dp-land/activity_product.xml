<?xml version="1.0" encoding="utf-8"?>
<!--
    10"+ tablet landscape split-view layout (sw720dp-land).
    Left panel (60%): products. Right panel (40%): cart with larger touch targets.
    Optimized for the most common POS hardware: 10" tablets in landscape.
-->
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="HardcodedText">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/root_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Guideline for 2-pane layout: 60% products / 40% cart -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.60" />

        <!-- ============ TOP BAR (left pane) ============ -->
        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/_10sdp"
            android:paddingEnd="@dimen/_10sdp"
            android:paddingTop="@dimen/_8sdp"
            android:paddingBottom="@dimen/_6sdp"
            android:background="#FAFAFA"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Drawer menu icon -->
            <ImageView
                android:id="@+id/drawer"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="Open menu"
                android:src="@drawable/ic_drawer"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Cart summary: qty only -->
            <TextView
                android:id="@+id/text_cart_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0X"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:fontFamily="@font/lexend_medium"
                android:textStyle="bold"
                android:minWidth="48dp"
                android:gravity="center" />

            <!-- Hidden for binding compatibility -->
            <TextView
                android:id="@+id/text_cart_total"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <!-- Separator -->
            <View
                android:id="@+id/separator_top_bar"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#E0E0E0"
                android:layout_marginStart="@dimen/_8sdp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- Last product added -->
            <LinearLayout
                android:id="@+id/layout_last_product"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="invisible">

                <ImageView
                    android:id="@+id/image_last_product"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:scaleType="centerCrop"
                    android:contentDescription="Last added product" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:id="@+id/text_last_product_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/text_last_product_price"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1976D2"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/button_undo"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="UNDO"
                    android:textColor="#E53935"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/stroke_btn"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hidden views for binding compatibility -->
        <ImageView
            android:id="@+id/search_customer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/button_more"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/textfield_search_product"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/button_search_product"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/spinner_select_product_category"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/text_view_customer_name"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Order type toggle (restaurant mode only) -->
        <LinearLayout
            android:id="@+id/layout_order_type"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="#FAFAFA"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/layout_top_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right">

            <TextView
                android:id="@+id/btn_dine_in"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/_8sdp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:text="DINE IN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/btn_rounded" />

            <TextView
                android:id="@+id/btn_take_away"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:gravity="center"
                android:text="TAKE AWAY"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/stroke_btn" />
        </LinearLayout>

        <!-- Category chips -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_categories"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_8sdp"
            android:layout_marginEnd="@dimen/_6sdp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:clipToPadding="false"
            android:background="#F0F0F0"
            app:layout_constraintTop_toBottomOf="@id/layout_order_type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right" />

        <!-- Divider -->
        <View
            android:id="@+id/divider_categories"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            app:layout_constraintTop_toBottomOf="@id/recycler_view_categories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right" />

        <!-- Loading spinner -->
        <ProgressBar
            android:id="@+id/progress_loading_products"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right"
            app:layout_constraintTop_toBottomOf="@id/divider_categories"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_buttons" />

        <!-- Empty state for products -->
        <include
            layout="@layout/empty_state"
            android:id="@+id/empty_state_products"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right"
            app:layout_constraintTop_toBottomOf="@id/divider_categories"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_buttons" />

        <!-- Product grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_search_product_result"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:clipToPadding="false"
            app:layout_constraintTop_toBottomOf="@id/divider_categories"
            app:layout_constraintBottom_toTopOf="@id/layout_bottom_buttons"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
            app:spanCount="4" />

        <!-- Bottom buttons (left pane) -->
        <LinearLayout
            android:id="@+id/layout_bottom_buttons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="@dimen/_6sdp"
            android:paddingEnd="@dimen/_6sdp"
            android:paddingBottom="@dimen/_6sdp"
            android:paddingTop="@dimen/_4sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideline_right">

            <TextView
                android:id="@+id/button_scan"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="SCAN"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/button_search_product_bottom"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="SEARCH"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/button_clear_cart"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="CLEAR"
                android:textColor="#E53935"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/stroke_btn" />

            <TextView
                android:id="@+id/button_add_customer"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:gravity="center"
                android:text="CUST"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/stroke_btn" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_more_bottom"
                android:saveEnabled="false"                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:gravity="center"
                android:text="MORE"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/stroke_btn" />
        </LinearLayout>

        <!-- Hidden MY CART button for binding compatibility -->
        <LinearLayout
            android:id="@+id/button_my_cart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/button_my_cart_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/button_my_cart_arrow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>

        <!-- ============ RIGHT PANE: CART ============ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/right_panel_cart"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/right_panel_border"
            android:translationZ="1dp"
            app:layout_constraintStart_toStartOf="@id/guideline_right"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- Cart title -->
            <TextView
                android:id="@+id/text_view_cart_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Cart (0)"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:gravity="center"
                android:paddingTop="@dimen/_8sdp"
                android:paddingBottom="@dimen/_6sdp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Cart items list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_cart_items"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/top_bottom_cart_border"
                app:layout_constraintTop_toBottomOf="@id/text_view_cart_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/text_view_promo_banner" />

            <!-- Promotion banner (inline cart) -->
            <TextView
                android:id="@+id/text_view_promo_banner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/posterita_secondary_light"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/posterita_secondary"
                android:textSize="11sp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/layout_totals" />

            <!-- Totals block -->
            <LinearLayout
                android:id="@+id/layout_totals"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="4dp"
                android:background="@color/white"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toTopOf="@id/layout_cart_buttons">

                <!-- Sub Total row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/text_view_sub_total_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sub Total"
                        android:textColor="@color/black"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/text_view_subtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Tax Total row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/text_view_tax_total_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tax Total"
                        android:textColor="@color/black"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/text_view_tax_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.00"
                        android:textColor="@color/black"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- Grand Total row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/text_view_total_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total (x0)"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="20sp" />

                    <TextView
                        android:id="@+id/text_view_grand_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rs0.00"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="20sp"
                        android:fontFamily="@font/lexend_medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Cart action buttons - larger for 10" tablets -->
            <LinearLayout
                android:id="@+id/layout_cart_buttons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/_6sdp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Hold Order -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/button_hold_order"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/stroke_btn">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hold Order"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- Coupon -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/button_coupon"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/stroke_btn">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coupon"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- More Options -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/button_more_options"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/stroke_btn">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="More"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <!-- PAY - large prominent button, 1.5x weight -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/button_pay_order"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1.5"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/btn_rounded">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAY"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:fontFamily="@font/lexend_medium"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Navigation Drawer -->
    <FrameLayout
        android:id="@+id/nav"
        android:layout_width="380dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:fitsSystemWindows="true">

        <include layout="@layout/nav_drawer_content" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
