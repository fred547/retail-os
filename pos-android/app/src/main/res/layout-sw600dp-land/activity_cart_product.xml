<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/my_drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="HardcodedText">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".Activities.ProductActivity">

        <ImageView
            android:id="@+id/drawer"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_drawer"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />





        <EditText
            android:id="@+id/edt_search"
            android:layout_width="@dimen/_100sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_marginStart="@dimen/_15sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:background="@drawable/white_start_rad"
            android:elevation="@dimen/_2sdp"
            android:hint="Search"
            android:maxLines="1"
            android:paddingStart="@dimen/_10sdp"
            android:textSize="@dimen/_10ssp"
            app:layout_constraintTop_toTopOf="parent"

            app:layout_constraintStart_toEndOf="@+id/drawer"
            android:textColor="@color/black" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/ic_searrch"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="@dimen/_15sdp"
            app:layout_constraintTop_toTopOf="parent"
            android:background="@drawable/blue_end_corner"
            app:layout_constraintStart_toEndOf="@+id/edt_search">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_search"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/catrc"
            android:layout_width="@dimen/_60sdp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintTop_toBottomOf="@id/edt_search"
            android:layout_marginTop="@dimen/_10ssp"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginStart="@dimen/_5sdp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@id/product"
            android:layout_width="@dimen/_200sdp"
            android:layout_height="0dp"
            android:layout_marginStart="8dp"
            android:layout_marginTop="@dimen/_10ssp"
            android:layout_marginBottom="@dimen/_5sdp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/catrc"
            app:layout_constraintTop_toBottomOf="@id/edt_search"
            app:layout_constraintVertical_bias="1.0" />

        <TextView
            android:id="@+id/cart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="@id/crdproduct"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="Cart"
            android:textSize="@dimen/_15ssp"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="@dimen/_8sdp"/>
        <ImageView
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            android:src="@drawable/ic_scanner"
            android:layout_marginEnd="@dimen/_5sdp"
            app:layout_constraintEnd_toStartOf="@id/clearcrt"
            app:layout_constraintTop_toTopOf="@id/clearcrt"
            app:layout_constraintBottom_toBottomOf="@id/clearcrt"/>
        <ImageView
            android:id="@+id/clearcrt"
            android:layout_width="@dimen/_20sdp"
            android:layout_height="@dimen/_20sdp"
            app:layout_constraintEnd_toEndOf="@id/crdproduct"
            android:src="@drawable/clear"
            app:layout_constraintTop_toTopOf="@+id/cart"
            app:layout_constraintBottom_toBottomOf="@id/txtusers"
            android:layout_marginEnd="@dimen/_5sdp"
            app:tint="@color/txt_color" />
        <ImageView
            android:id="@+id/img"
            android:layout_width="@dimen/_10sdp"
            android:layout_height="@dimen/_10sdp"
            app:layout_constraintStart_toStartOf="@id/crdproduct"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/_1sdp"
            app:layout_constraintEnd_toStartOf="@id/txtusers"
            app:layout_constraintTop_toBottomOf="@id/cart"
            app:layout_constraintHorizontal_chainStyle="packed"
            android:src="@drawable/ic_selectuser_blue"/>
        <TextView
            android:id="@+id/txtusers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Customer"
            android:layout_marginStart="@dimen/_3sdp"
            app:layout_constraintStart_toEndOf="@+id/img"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cart"
            android:textColor="@color/posterita_primary"
            android:textSize="@dimen/_8ssp"
            android:textStyle="bold"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/crdproduct"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_margin="5dp"
            tools:listitem="@layout/item"
            app:layout_constraintTop_toBottomOf="@+id/txtusers"
            app:layout_constraintBottom_toTopOf="@id/consbotom"
            app:layout_constraintStart_toEndOf="@id/product"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/consbotom"
            android:layout_width="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/product"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/_10sdp"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@color/posterita_paper"
            android:paddingTop="6dp">
            <TextView
                android:id="@+id/txt_sub_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_8ssp"
                android:textColor="@color/posterita_ink"
                android:text="Sub total"
                app:layout_constraintBottom_toTopOf="@id/txt_tex_totoal_amount"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/txt_tex_totoal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_8ssp"
                android:textColor="@color/posterita_ink"
                android:text="Tax total"
                app:layout_constraintBottom_toTopOf="@id/txtamountbold"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/txt_sub_totoal_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_8ssp"
                android:textColor="@color/posterita_ink"
                android:text="0.00"
                app:layout_constraintBottom_toTopOf="@id/txt_tex_totoal_amount"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:id="@+id/txt_tex_totoal_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/_8ssp"
                android:textColor="@color/posterita_ink"
                android:text="0.00"
                app:layout_constraintBottom_toTopOf="@id/txtamountbold"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_5sdp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textColor="@color/posterita_ink"
                android:fontFamily="@font/lexend_medium"
                app:layout_constraintBottom_toTopOf="@+id/const_pay"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginBottom="@dimen/_5sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:textSize="@dimen/_8ssp"/>
            <TextView
                android:id="@+id/txtamountbold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textColor="@color/posterita_ink"
                android:fontFamily="@font/lexend_medium"
                app:layout_constraintBottom_toTopOf="@+id/const_pay"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginBottom="@dimen/_5sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:textSize="@dimen/_8ssp"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/const_hold"
                android:layout_width="0dp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_height="@dimen/_20sdp"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintEnd_toStartOf="@+id/const_pay"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                android:background="@drawable/stroke_btn">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hold Order"
                    android:textSize="@dimen/_8ssp"
                    android:fontFamily="@font/lexend_medium"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/posterita_ink"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/const_pay"
                android:layout_width="0dp"
                android:layout_height="@dimen/_20sdp"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:layout_marginBottom="@dimen/_10sdp"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/const_hold"
                app:layout_constraintBottom_toBottomOf="parent"
                android:background="@drawable/btn_rounded">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pay"
                    android:textSize="@dimen/_8ssp"
                    android:fontFamily="@font/lexend_medium"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:textColor="@color/white"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="wrap_content"
        android:id="@+id/nav"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_home"
        android:layout_gravity="start"
        app:menu="@menu/navigation_menu" />

</androidx.drawerlayout.widget.DrawerLayout>