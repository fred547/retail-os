<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="0.2dp"
    app:cardCornerRadius="@dimen/_5sdp"
    app:cardElevation="@dimen/_1sdp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    >

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/_5sdp"
        android:paddingStart="@dimen/_6sdp"
        android:paddingEnd="@dimen/_6sdp"
        >

        <!-- Product image -->
        <ImageView
            android:id="@+id/image_view_product"
            android:layout_width="@dimen/_15sdp"
            android:layout_height="@dimen/_15sdp"
            android:layout_marginStart="@dimen/_1sdp"
            android:layout_marginTop="@dimen/_1sdp"
            android:layout_marginBottom="@dimen/_1sdp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_product_placeholder"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount" />



        <!-- Quantity -->
        <TextView
            android:id="@+id/text_view_qty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="13"
            android:textColor="@color/black"
            android:textSize="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"
            />

        <TextView
            android:id="@+id/text_view_x"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:text="X"
            android:textColor="@color/black"
            android:textSize="15dp"
            app:layout_constraintStart_toEndOf="@id/text_view_qty"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"
            />


        <!-- Product name: up to 2 lines, no overlap with right buttons -->
        <TextView
            android:id="@+id/text_view_product_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_5sdp"
            android:layout_marginTop="@dimen/_1sdp"

            android:ellipsize="end"
            android:maxLines="2"
            android:text="Orange cake"
            android:textColor="@color/black"
            android:textSize="15dp"
            app:layout_constraintEnd_toStartOf="@id/text_view_product_price"
            app:layout_constraintStart_toEndOf="@id/text_view_x"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"
            />

        <!-- Product price -->
        <TextView
            android:id="@+id/text_view_product_price"
            android:layout_width="@dimen/_24sdp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_4sdp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="18dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="20000.00"
            android:textColor="@color/blue"
            android:textSize="15dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/text_view_product_name"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"

            />

        <!-- Remove (delete) button - fixed top-right -->
        <ImageView
            android:id="@+id/button_remove_line"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_del"
            app:layout_constraintStart_toEndOf="@id/text_view_product_price"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Minus button container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_remove"
            android:layout_width="@dimen/_9sdp"
            android:layout_height="@dimen/_9sdp"
            android:layout_marginEnd="@dimen/_4sdp"
            android:visibility="gone"
            android:background="@drawable/circle_drawable"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"
            app:layout_constraintEnd_toStartOf="@id/text_view_qty">

            <ImageView
                android:id="@+id/button_decrease_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_remove"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>



        <!-- Plus button container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cons_add"
            android:layout_width="@dimen/_9sdp"
            android:layout_height="@dimen/_9sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:visibility="gone"
            android:background="@drawable/circle_drawable"
            app:layout_constraintBottom_toTopOf="@id/text_view_discount_amount"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/button_increase_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_add"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Discount line at the bottom -->
        <TextView
            android:id="@+id/text_view_discount_amount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:gravity=""

            android:paddingBottom="@dimen/_1sdp"
            android:text="Discount: ₨ 12.00"
            android:layout_marginStart="@dimen/_12sdp"
            android:textColor="@android:color/darker_gray"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/image_view_product"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
             />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
