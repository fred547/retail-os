# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Claude AI (for server-side AI operations)
CLAUDE_API_KEY=your-claude-api-key

# Blink Payment Integration (Emtel)
BLINK_MODE=UAT
BLINK_DQR_UAT_AES_KEY=your-dynamic-qr-aes-key
BLINK_DQR_UAT_AES_IV=your-dynamic-qr-aes-iv
BLINK_DQR_UAT_USERNAME=your-dynamic-qr-username
BLINK_DQR_UAT_PASSWORD=your-dynamic-qr-password
BLINK_TILL_UAT_AES_KEY=your-till-aes-key
BLINK_TILL_UAT_AES_IV=your-till-aes-iv
BLINK_TILL_UAT_USERNAME=your-till-username
BLINK_TILL_UAT_PASSWORD=your-till-password
