package ebs;

import com.fasterxml.jackson.databind.ObjectMapper;
import ebs.exceptions.CertificateException;
import ebs.models.Invoice;
import ebs.models.response.AuthenticateResponse;
import ebs.models.response.TransmitInvoiceResponse;
import java.io.BufferedReader;
import java.io.ByteArrayInputStream;
import java.io.File;
import java.io.FileInputStream;
import java.io.InputStreamReader;
import java.io.OutputStream;
import java.math.BigDecimal;
import java.net.HttpURLConnection;
import java.net.URL;
import java.nio.charset.StandardCharsets;
import java.security.InvalidKeyException;
import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;
import java.security.PublicKey;
import java.security.cert.CertificateFactory;
import java.security.cert.X509Certificate;
import java.text.SimpleDateFormat;
import java.util.Base64;
import java.util.Date;
import java.util.HashMap;
import java.util.Map;
import java.util.UUID;
import javax.crypto.BadPaddingException;
import javax.crypto.Cipher;
import javax.crypto.IllegalBlockSizeException;
import javax.crypto.KeyGenerator;
import javax.crypto.NoSuchPaddingException;
import javax.crypto.SecretKey;
import javax.crypto.spec.SecretKeySpec;
import org.json.JSONObject;

public class EbsMraClient {
  private String username;
  
  private String password;
  
  private String ebsMraId;
  
  private String areaCode;
  
  private String token;
  
  private String tokenExpiryDate;
  
  private String secretKey;
  
  private TokenRepository tokenRepository;
  
  static final String CERTIFICATE = "";
  
  public EbsMraClient(String username, String password, String ebsMraId, String areaCode) {
    this.username = username;
    this.password = password;
    this.ebsMraId = ebsMraId;
    this.areaCode = areaCode;
  }
  
  public EbsMraClient(String username, String password, String ebsMraId, String areaCode, TokenRepository tokenRepository) {
    this(username, password, ebsMraId, areaCode);
    this.tokenRepository = tokenRepository;
  }
  
  public void setTokenInfo(String token, String tokenExpiryDate, String secretKey) {
    this.token = token;
    this.tokenExpiryDate = tokenExpiryDate;
    this.secretKey = secretKey;
  }
  
  public AuthenticateResponse authenticate(boolean refreshToken) throws Exception {
    String encryptKey = generateRandomAESkey();
    JSONObject payloadInput = new JSONObject();
    payloadInput.put("username", this.username);
    payloadInput.put("password", this.password);
    payloadInput.put("encryptKey", encryptKey);
    payloadInput.put("refreshToken", refreshToken ? "true" : "false");
    String payload = encodeToBase64(encryptUsingMraRSACertificate("", payloadInput.toString()));
    JSONObject body = new JSONObject();
    body.put("requestId", UUID.randomUUID().toString());
    body.put("payload", payload);
    Map<String, String> headers = new HashMap<>();
    headers.put("username", this.username);
    headers.put("ebsMraId", this.ebsMraId);
    headers.put("areaCode", this.areaCode);
    String url = "https://vfisc.mra.mu/einvoice-token-service/token-api/generate-token";
    String response = _post(url, headers, body.toString());
    ObjectMapper objectMapper = new ObjectMapper();
    AuthenticateResponse tokenResponse = (AuthenticateResponse)objectMapper.readValue(response, AuthenticateResponse.class);
    if ("SUCCESS".equalsIgnoreCase(tokenResponse.getStatus())) {
      String encryptedSecretKey = tokenResponse.getKey();
      String decryptedSecretKey = decryptTokenKey(encryptKey, encryptedSecretKey);
      tokenResponse.setKey(decryptedSecretKey);
      setTokenInfo(tokenResponse.getToken(), tokenResponse.getExpiryDate(), tokenResponse.getKey());
      if (this.tokenRepository != null) {
        this.tokenRepository.setToken(this.token);
        this.tokenRepository.setTokenExpiryDate(this.tokenExpiryDate);
        this.tokenRepository.setSecretKey(this.secretKey);
        this.tokenRepository.save();
      } 
    } 
    return tokenResponse;
  }
  
  public byte[] encryptUsingMraRSACertificate(String message) throws Exception {
    String path = System.getProperty("MRA_PUBLIC_KEY_CERTIFICATE_PATH", "");
    if (path.length() == 0)
      throw new CertificateException("Environment variable: MRA_PUBLIC_KEY_CERTIFICATE_PATH not found!"); 
    File f = new File(path);
    if (!f.exists())
      throw new CertificateException(String.format("Certificate %s not found!", new Object[] { path })); 
    FileInputStream fileInputStream = new FileInputStream(f);
    CertificateFactory cf = CertificateFactory.getInstance("X.509");
    X509Certificate cert = (X509Certificate)cf.generateCertificate(fileInputStream);
    PublicKey publicKey = cert.getPublicKey();
    byte[] messageToBytes = message.getBytes();
    Cipher cipher = Cipher.getInstance("RSA/ECB/PKCS1Padding");
    cipher.init(1, publicKey);
    return cipher.doFinal(messageToBytes);
  }
  
  public byte[] encryptUsingMraRSACertificate(String certificate, String message) throws Exception {
    byte[] decodedCertificate = decodeFromBase64(certificate);
    CertificateFactory cf = CertificateFactory.getInstance("X.509");
    X509Certificate cert = (X509Certificate)cf.generateCertificate(new ByteArrayInputStream(decodedCertificate));
    PublicKey publicKey = cert.getPublicKey();
    byte[] messageToBytes = message.getBytes();
    Cipher cipher = Cipher.getInstance("RSA/ECB/PKCS1Padding");
    cipher.init(1, publicKey);
    return cipher.doFinal(messageToBytes);
  }
  
  public String generateRandomAESkey() throws Exception {
    KeyGenerator keyGenerator = KeyGenerator.getInstance("AES");
    keyGenerator.init(256);
    SecretKey secretKey = keyGenerator.generateKey();
    byte[] keyBytes = secretKey.getEncoded();
    String base64EncodedKey = encodeToBase64(keyBytes);
    return base64EncodedKey;
  }
  
  public String decryptTokenKey(String secretKey, String encryptedTokenKey) throws NoSuchAlgorithmException, NoSuchPaddingException, InvalidKeyException, IllegalBlockSizeException, BadPaddingException {
    SecretKeySpec spec = new SecretKeySpec(decodeFromBase64(secretKey), "AES");
    Cipher cipher = Cipher.getInstance("AES/ECB/PKCS5Padding");
    cipher.init(2, spec);
    byte[] encryptedKeyBytes = decodeFromBase64(encryptedTokenKey);
    byte[] decryptedKeyBytes = cipher.doFinal(encryptedKeyBytes);
    String decryptedKey = new String(decryptedKeyBytes, StandardCharsets.UTF_8);
    return decryptedKey;
  }
  
  public String encrypt(String base64EncodedSecretKey, String data) throws NoSuchAlgorithmException, NoSuchPaddingException, InvalidKeyException, IllegalBlockSizeException, BadPaddingException {
    byte[] aesKeyBytes = decodeFromBase64(base64EncodedSecretKey);
    SecretKey aesKey = new SecretKeySpec(aesKeyBytes, "AES");
    Cipher cipher = Cipher.getInstance("AES/ECB/PKCS5PADDING");
    cipher.init(1, aesKey);
    byte[] b = cipher.doFinal(data.getBytes());
    return encodeToBase64(b);
  }
  
  public static String previousNoteHash(String dateTime, BigDecimal totalAmtPaid, String brn, String invoiceIdentifier) throws NoSuchAlgorithmException {
    StringBuffer sb = (new StringBuffer(dateTime)).append(totalAmtPaid).append(brn).append(invoiceIdentifier);
    String concatenated_value = sb.toString();
    MessageDigest md = MessageDigest.getInstance("SHA-256");
    byte[] bytes = md.digest(concatenated_value.getBytes());
    sb = new StringBuffer();
    byte b;
    int i;
    byte[] arrayOfByte1;
    for (i = (arrayOfByte1 = bytes).length, b = 0; b < i; ) {
      byte b1 = arrayOfByte1[b];
      sb.append(String.format("%02X", new Object[] { Byte.valueOf(b1) }));
      b++;
    } 
    String previousNoteHash = sb.toString();
    return previousNoteHash;
  }
  
  public void validateToken() {}
  
  public TransmitInvoiceResponse transmitInvoice(Invoice[] invoices) throws Exception {
    String encryptedInvoice;
    ObjectMapper objectMapper = new ObjectMapper();
    String invoiceJson = objectMapper.writeValueAsString(invoices);
    try {
      encryptedInvoice = encrypt(this.secretKey, invoiceJson);
    } catch (Exception e) {
      throw e;
    } 
    SimpleDateFormat sdf = new SimpleDateFormat("yyyyMMdd HH:mm:ss");
    JSONObject body = new JSONObject();
    body.put("requestId", UUID.randomUUID().toString());
    body.put("requestDateTime", sdf.format(new Date()));
    body.put("encryptedInvoice", encryptedInvoice);
    Map<String, String> headers = new HashMap<>();
    headers.put("username", this.username);
    headers.put("ebsMraId", this.ebsMraId);
    headers.put("areaCode", this.areaCode);
    headers.put("token", this.token);
    String url = "https://vfisc.mra.mu/realtime/invoice/transmit";
    String response = _post(url, headers, body.toString());
    return (TransmitInvoiceResponse)objectMapper.readValue(response, TransmitInvoiceResponse.class);
  }
  
  public String getUsername() {
    return this.username;
  }
  
  public void setUsername(String username) {
    this.username = username;
  }
  
  public String getPassword() {
    return this.password;
  }
  
  public void setPassword(String password) {
    this.password = password;
  }
  
  public String getEbsMraId() {
    return this.ebsMraId;
  }
  
  public void setEbsMraId(String ebsMraId) {
    this.ebsMraId = ebsMraId;
  }
  
  public String getAreaCode() {
    return this.areaCode;
  }
  
  public void setAreaCode(String areaCode) {
    this.areaCode = areaCode;
  }
  
  public String getToken() {
    return this.token;
  }
  
  public void setToken(String token) {
    this.token = token;
  }
  
  public String getTokenExpiryDate() {
    return this.tokenExpiryDate;
  }
  
  public void setTokenExpiryDate(String tokenExpiryDate) {
    this.tokenExpiryDate = tokenExpiryDate;
  }
  
  public String getSecretKey() {
    return this.secretKey;
  }
  
  public void setSecretKey(String secretKey) {
    this.secretKey = secretKey;
  }
  
  public TokenRepository getTokenRepository() {
    return this.tokenRepository;
  }
  
  public void setTokenRepository(TokenRepository tokenRepository) {
    this.tokenRepository = tokenRepository;
    if (this.tokenRepository != null) {
      this.tokenRepository.load();
      setTokenInfo(this.tokenRepository.getToken(), this.tokenRepository.getTokenExpiryDate(), this.tokenRepository.getSecretKey());
    } 
  }
  
  private String _post(String url, Map<String, String> headers, String requestBody) throws Exception {
    try {
      BufferedReader in;
      HttpURLConnection connection = (HttpURLConnection)(new URL(url)).openConnection();
      connection.setRequestMethod("POST");
      connection.setRequestProperty("Content-Type", "application/json");
      for (Map.Entry<String, String> entry : headers.entrySet())
        connection.setRequestProperty(entry.getKey(), entry.getValue()); 
      connection.setDoOutput(true);
      connection.setConnectTimeout(5000);
      OutputStream os = connection.getOutputStream();
      byte[] input = requestBody.getBytes("utf-8");
      os.write(input, 0, input.length);
      os.flush();
      os.close();
      int responseCode = connection.getResponseCode();
      if (responseCode >= 400) {
        in = new BufferedReader(new InputStreamReader(connection.getErrorStream()));
      } else {
        in = new BufferedReader(new InputStreamReader(connection.getInputStream()));
      } 
      StringBuilder response = new StringBuilder();
      String inputLine;
      while ((inputLine = in.readLine()) != null)
        response.append(inputLine); 
      in.close();
      connection.disconnect();
      return response.toString();
    } catch (Exception e) {
      throw e;
    } 
  }
  
  public String encodeToBase64(byte[] input) {
    return Base64.getEncoder().encodeToString(input);
  }
  
  public byte[] decodeFromBase64(String input) {
    return Base64.getDecoder().decode(input);
  }
}
